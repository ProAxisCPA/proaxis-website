---
export interface Props {
  heading?: string;
  subheading?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCta?: boolean;
  variant?: 'dark' | 'light' | 'blue';
}

const {
  heading = "Ready to Take Control of Your Taxes and Finances?",
  subheading = "Schedule a free consultation with our Bergen County CPA team. Fully virtual, no pressure — just expert guidance tailored to your situation.",
  ctaText = "Book Your Free Consultation",
  ctaHref = "https://outlook.office.com/book/ProAxisTaxandAccountingServicesCPA@proaxiscpa.com/?ismsaljsauthenabled",
  secondaryCta = true,
  variant = 'dark',
} = Astro.props;

const bgClass = variant === 'dark'
  ? 'bg-navy'
  : variant === 'blue'
  ? 'bg-blue-brand'
  : 'bg-alt';

const textClass = variant === 'light' ? 'text-navy' : 'text-white';
const subTextClass = variant === 'light' ? 'text-gray-600' : 'text-gray-300';
---

<section class={`py-16 lg:py-20 ${variant === 'dark' ? '' : variant === 'blue' ? '' : ''}`} style={variant === 'dark' ? 'background-color: #1C1C1E;' : variant === 'blue' ? 'background-color: #2E75B6;' : 'background-color: #F7F8FA;'}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class={`text-2xl sm:text-3xl lg:text-4xl font-bold font-heading mb-4 ${variant === 'light' ? '' : 'text-white'}`}
      style={variant === 'light' ? 'color: #1C1C1E;' : ''}
    >
      {heading}
    </h2>
    <p class={`text-lg mb-8 max-w-2xl mx-auto ${variant === 'light' ? 'text-gray-600' : 'text-gray-300'}`}>
      {subheading}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={ctaHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-lg text-base font-semibold transition-all hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2"
        style="background-color: #E5E4E2; color: #1C1C1E;"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        {ctaText}
      </a>
      {secondaryCta && (
        <a
          href="tel:+12018002330"
          class={`inline-flex items-center gap-2 px-7 py-3.5 rounded-lg text-base font-semibold border-2 transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 ${variant === 'light' ? 'border-navy text-navy hover:bg-navy hover:text-white' : 'border-white text-white hover:bg-white/10'}`}
          style={variant === 'light' ? 'border-color: #1C1C1E; color: #1C1C1E;' : ''}
          aria-label="Call ProAxis at (201) 800-2330"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (201) 800-2330
        </a>
      )}
    </div>
  </div>
</section>
