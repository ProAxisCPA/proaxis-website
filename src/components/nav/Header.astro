            <span class="block text-xs mt-0.5" style="color: #6B6E78;">S-Corps, partnerships, multi-member LLCs</span>
          </a>
          <a href="/tax-intake/corporate/" class="block px-4 py-2.5 mx-1 mb-1 rounded-lg transition-colors" style="color: #E5E4E2;" onmouseover="this.style.backgroundColor='#2a2a2e'" onmouseout="this.style.backgroundColor='transparent'">
