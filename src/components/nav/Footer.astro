---
const currentYear = new Date().getFullYear();

const napSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "AccountingService"],
  "name": "ProAxis Tax & Accounting Services",
  "telephone": "+12018002330",
  "email": "info@proaxiscpa.com",
  "url": "https://www.proaxiscpa.com",
  "logo": "https://www.proaxiscpa.com/logo.png",
  "image": "https://www.proaxiscpa.com/og-image.png",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Hasbrouck Heights",
    "addressLocality": "Hasbrouck Heights",
    "addressRegion": "NJ",
    "postalCode": "07604",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.8598,
    "longitude": -74.0776
  },
  "areaServed": [
    { "@type": "County", "name": "Bergen County, NJ" },
    { "@type": "State", "name": "New Jersey" },
    { "@type": "State", "name": "New York" }
  ],
  "sameAs": [
    "https://www.proaxiscpa.com"
  ]
};
---

<script type="application/ld+json" set:html={JSON.stringify(napSchema)} />

<footer class="text-white" style="background-color: #1C1C1E;" role="contentinfo">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-10">

      <!-- Company Info / NAP -->
      <div class="lg:col-span-2">
        <div class="mb-4">
          <img
            src="/proaxis-logo.png"
            alt="ProAxis Tax & Accounting Services"
            width="595"
            height="169"
            class="h-9 w-auto brightness-0 invert"
            style="max-width: 200px;"
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-4">
          Bergen County's technology-first CPA firm. We serve small-to-mid-size businesses, executives, and high-income individuals across New Jersey and the greater New York area — fully virtually.
        </p>
        <!-- NAP — consistent across site -->
        <address class="not-italic space-y-2 text-sm">
          <div class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" style="color: #C5A55A; min-width:1rem;">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-gray-400">Hasbrouck Heights, NJ 07604<br /><span class="text-xs">(Fully virtual — no office visits required)</span></span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" style="color: #C5A55A; min-width:1rem;">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
