---
export interface Props {
  heading?: string;
  variant?: 'light' | 'dark';
}
const {
  heading = "What Our Clients Say",
  variant = 'light',
} = Astro.props;

const testimonials = [
  {
    quote: "Working with ProAxis has made tax season very stress free. Their team is always available to answer questions and the proactive approach to planning means no surprises when April comes around.",
    author: "Lexi W.",
    role: "Small Business Owner, Bergen County NJ",
    rating: 5,
  },
  {
    quote: "Partnering with ProAxis completely changed my experience during tax season. For the first time I actually feel like I understand my tax situation, and I'm saving money because of it.",
    author: "Navit S.",
    role: "Real Estate Investor, NJ",
    rating: 5,
  },
  {
    quote: "Great working with ProAxis Tax & Accounting, super quick turnaround and VERY responsive, highly recommend! They handled our business accounting and made the whole process seamless.",
    author: "Jorden I.",
    role: "Business Owner, New Jersey",
    rating: 5,
  },
];
---

<section class={`py-14 lg:py-20 ${variant === 'dark' ? '' : ''}`} style={variant === 'dark' ? 'background-color: #1C1C1E;' : 'background-color: #F7F8FA;'} aria-labelledby="testimonials-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 id="testimonials-heading" class={`text-2xl sm:text-3xl font-bold font-heading ${variant === 'dark' ? 'text-white' : ''}`} style={variant === 'dark' ? '' : 'color: #1C1C1E;'}>
        {heading}
      </h2>
      <p class={`mt-3 text-lg ${variant === 'dark' ? 'text-gray-300' : 'text-gray-600'}`}>
        Trusted by business owners and individuals across Bergen County and New Jersey
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div
          class={`rounded-xl p-6 shadow-sm ${variant === 'dark' ? 'bg-white/10 border border-white/10' : 'bg-white border border-gray-100'}`}
          itemscope
          itemtype="https://schema.org/Review"
        >
          <!-- Stars -->
          <div class="flex gap-1 mb-4" aria-label={`${t.rating} out of 5 stars`} role="img">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" style="color: #C5A55A;">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class={`text-sm leading-relaxed mb-4 italic ${variant === 'dark' ? 'text-gray-300' : 'text-gray-700'}`} itemprop="reviewBody">
            "{t.quote}"
          </blockquote>

          <!-- Author -->
          <div itemprop="author" itemscope itemtype="https://schema.org/Person">
            <p class={`font-semibold text-sm font-heading ${variant === 'dark' ? 'text-white' : ''}`} style={variant === 'dark' ? '' : 'color: #1C1C1E;'} itemprop="name">
              — {t.author}
            </p>
            <p class={`text-xs mt-0.5 ${variant === 'dark' ? 'text-gray-400' : 'text-gray-500'}`}>{t.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
