---
---
<section class="border-y border-gray-100 py-6" style="background-color: #F7F8FA;" aria-label="Trust credentials and certifications">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap items-center justify-center gap-6 lg:gap-10">
      <div class="flex items-center gap-2.5">
        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #1B2A4A;">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 leading-none">Member</p>
          <p class="text-sm font-semibold font-heading" style="color: #1B2A4A;">AICPA</p>
        </div>
      </div>

      <div class="flex items-center gap-2.5">
        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #2E75B6;">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 leading-none">Authorized</p>
          <p class="text-sm font-semibold font-heading" style="color: #1B2A4A;">IRS e-File Provider</p>
        </div>
      </div>

      <div class="flex items-center gap-2.5">
        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #22C55E;">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 leading-none">Certified</p>
          <p class="text-sm font-semibold font-heading" style="color: #1B2A4A;">QuickBooks ProAdvisor</p>
        </div>
      </div>

      <div class="flex items-center gap-2.5">
        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #C5A55A;">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 leading-none">256-bit</p>
          <p class="text-sm font-semibold font-heading" style="color: #1B2A4A;">Secure Encryption</p>
        </div>
      </div>

      <div class="flex items-center gap-2.5">
        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #1B2A4A;">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 leading-none">Licensed CPAs</p>
          <p class="text-sm font-semibold font-heading" style="color: #1B2A4A;">State of New Jersey</p>
        </div>
      </div>
    </div>
  </div>
</section>
