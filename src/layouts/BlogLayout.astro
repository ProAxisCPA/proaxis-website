---
import BaseLayout from './BaseLayout.astro';
import CTASection from '../components/ui/CTASection.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';

export interface Props {
  title: string;
  description: string;
  metaTitle?: string;
  metaDescription?: string;
  date: Date;
  author: string;
  category: string;
  tags: string[];
  readTime?: number;
  slug: string;
  image?: string;
  imageAlt?: string;
}

const {
  title,
  description,
  metaTitle,
  metaDescription,
  date,
  author,
  category,
  tags,
  readTime,
  slug,
  image,
  imageAlt,
} = Astro.props;

const siteUrl = 'https://www.proaxiscpa.com';
const canonical = `/resources/blog/${slug}/`;
const ogImage = image || `${siteUrl}/og-image.png`;
const publishDate = date.toISOString();
const breadcrumbs = [
  { name: "Resources", url: "/resources/blog/" },
  { name: "Blog", url: "/resources/blog/" },
  { name: title },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "datePublished": publishDate,
    "dateModified": publishDate,
    "author": {
      "@type": "Organization",
      "name": author,
      "url": siteUrl
    },
    "publisher": {
      "@type": "Organization",
      "name": "ProAxis Tax & Accounting Services",
      "logo": {
        "@type": "ImageObject",
        "url": `${siteUrl}/logo.png`
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `${siteUrl}${canonical}`
    },
    "image": ogImage,
    "url": `${siteUrl}${canonical}`,
    "keywords": tags.join(", "),
    "articleSection": category,
    "inLanguage": "en-US"
  }
];

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout
  title={metaTitle || title}
  description={metaDescription || description}
  canonical={canonical}
  ogType="article"
  ogImage={ogImage}
  {schema}
  breadcrumbs={breadcrumbs}
>
  <Breadcrumbs items={[
    { name: "Resources", url: "/resources/blog/" },
    { name: "Blog", url: "/resources/blog/" },
    { name: title }
  ]} />

  <!-- Article Hero -->
  <section style="background-color: #F7F8FA;" class="py-10 border-b border-gray-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Category tag -->
      <div class="mb-4">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold text-white" style="background-color: #2E75B6;">{category}</span>
      </div>
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold font-heading mb-4 leading-tight" style="color: #1C1C1E;">{title}</h1>
      <p class="text-lg text-gray-600 mb-5">{description}</p>
      <!-- Meta info -->
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <span>By {author}</span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <time datetime={publishDate}>{formattedDate}</time>
        </div>
        {readTime && (
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>{readTime} min read</span>
          </div>
        )}
      </div>
      <!-- Tags -->
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-white border border-gray-200" style="color: #1C1C1E;">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Article Content -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
      <article class="lg:col-span-3 prose-proaxis">
        <slot />
      </article>

      <!-- Sidebar -->
      <aside class="lg:col-span-1 space-y-6">
        <!-- Sticky CTA sidebar -->
        <div class="sticky top-24 space-y-5">
          <!-- CTA Card -->
          <div class="rounded-xl p-5 text-white" style="background-color: #1C1C1E;">
            <h3 class="font-bold font-heading text-base mb-2">Need Help?</h3>
            <p class="text-gray-300 text-xs mb-4 leading-relaxed">Our Bergen County CPAs are ready to help with all your tax and accounting needs.</p>
            <a href="/contact/" class="block w-full text-center px-4 py-2.5 rounded-lg text-sm font-semibold text-white transition-all hover:opacity-90" style="background-color: #22C55E;">
              Free Consultation
            </a>
            <a href="tel:+12018002330" class="block w-full text-center mt-2 px-4 py-2.5 rounded-lg text-sm font-semibold border border-white/30 text-white hover:bg-white/10 transition-all">
              (201) 800-2330
            </a>
          </div>

          <!-- Related Services -->
          <div class="rounded-xl border border-gray-100 p-5 bg-white">
            <h3 class="font-bold font-heading text-sm mb-3" style="color: #1C1C1E;">Our Services</h3>
            <ul class="space-y-2">
              <li><a href="/tax-services/tax-planning/" class="text-xs hover:text-blue-700 transition-colors" style="color: #2E75B6;">Tax Planning & Strategy</a></li>
              <li><a href="/tax-services/tax-preparation/" class="text-xs hover:text-blue-700 transition-colors" style="color: #2E75B6;">Tax Preparation</a></li>
              <li><a href="/business-services/bookkeeping/" class="text-xs hover:text-blue-700 transition-colors" style="color: #2E75B6;">Bookkeeping Services</a></li>
              <li><a href="/business-services/fractional-cfo/" class="text-xs hover:text-blue-700 transition-colors" style="color: #2E75B6;">Fractional CFO</a></li>
              <li><a href="/tax-services/irs-tax-resolution/" class="text-xs hover:text-blue-700 transition-colors" style="color: #2E75B6;">IRS Tax Resolution</a></li>
            </ul>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <!-- Bottom CTA -->
  <CTASection
    heading="Questions About Your Tax Situation?"
    subheading="Our Bergen County CPA team can help. Schedule a free consultation and get expert guidance tailored to your specific situation."
  />
</BaseLayout>
