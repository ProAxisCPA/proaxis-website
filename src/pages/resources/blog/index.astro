---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/ui/Breadcrumbs.astro';
import CTASection from '../../../components/ui/CTASection.astro';

const title = "Tax & Accounting Blog | NJ Business Resources | ProAxis CPA";
const description = "ProAxis CPA's blog for NJ business owners. Expert insights on tax planning, NJ tax law, accounting best practices, and financial strategy for Bergen County businesses.";
const canonical = "/resources/blog/";
const breadcrumbs = [{ name: "Resources", url: "/resources/blog/" }, { name: "Blog" }];

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const featuredPost = sortedPosts.find(p => p.data.featured) || sortedPosts[0];
const regularPosts = sortedPosts.filter(p => p.id !== featuredPost?.id);

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "ProAxis Tax & Accounting Blog",
  "description": "Expert tax and accounting insights for NJ business owners",
  "url": "https://www.proaxiscpa.com/resources/blog/",
  "publisher": {
    "@type": "Organization",
    "name": "ProAxis Tax & Accounting Services"
  }
};
---

<BaseLayout {title} {description} {canonical} {schema} {breadcrumbs}>
  <Breadcrumbs items={breadcrumbs} />

  <!-- Hero -->
  <section style="background: linear-gradient(135deg, #1B2A4A 0%, #2E75B6 100%);" class="py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl sm:text-4xl font-bold font-heading text-white mb-3">
        Tax & Accounting Insights for NJ Business Owners
      </h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        Expert guidance on NJ tax law, business accounting, financial strategy, and IRS updates — written by licensed CPAs for Bergen County business owners.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">

    {/* Featured Post */}
    {featuredPost && (
      <div class="mb-12">
        <h2 class="text-lg font-bold font-heading mb-5" style="color: #1B2A4A;">Featured Article</h2>
        <a href={`/resources/blog/${featuredPost.id}/`} class="group block rounded-2xl border border-gray-100 bg-white overflow-hidden hover:shadow-lg transition-all">
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="min-h-52 flex items-center justify-center p-8" style="background: linear-gradient(135deg, #1B2A4A 0%, #2E75B6 100%);">
              <div class="text-center">
                <div class="text-5xl mb-3" aria-hidden="true">📝</div>
                <p class="text-white/60 text-sm">Featured Article</p>
                <p class="text-white/40 text-xs mt-1">Replace with featured image</p>
              </div>
            </div>
            <div class="p-8 flex flex-col justify-center">
              <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold text-white mb-3" style="background-color: #2E75B6;">{featuredPost.data.category}</span>
              <h3 class="text-xl font-bold font-heading mb-3 group-hover:text-blue-700 transition-colors" style="color: #1B2A4A;">{featuredPost.data.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">{featuredPost.data.description}</p>
              <div class="flex items-center gap-4 text-xs text-gray-500">
                <span>{featuredPost.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                {featuredPost.data.readTime && <span>{featuredPost.data.readTime} min read</span>}
              </div>
            </div>
          </div>
        </a>
      </div>
    )}

    {/* All Posts Grid */}
    {regularPosts.length > 0 && (
      <div>
        <h2 class="text-lg font-bold font-heading mb-5" style="color: #1B2A4A;">All Articles</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {regularPosts.map(post => (
            <a href={`/resources/blog/${post.id}/`} class="group block rounded-xl border border-gray-100 bg-white overflow-hidden hover:shadow-md transition-all">
              <div class="h-40 flex items-center justify-center" style="background: linear-gradient(135deg, #F7F8FA 0%, #EEF3FA 100%);">
                <div class="text-center">
                  <div class="text-3xl mb-1" aria-hidden="true">📄</div>
                  <p class="text-gray-400 text-xs">Article image placeholder</p>
                </div>
              </div>
              <div class="p-5">
                <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold text-white mb-2" style="background-color: #2E75B6;">{post.data.category}</span>
                <h3 class="font-bold font-heading text-sm mb-2 group-hover:text-blue-700 transition-colors leading-snug" style="color: #1B2A4A;">{post.data.title}</h3>
                <p class="text-gray-500 text-xs leading-relaxed mb-3 line-clamp-2">{post.data.description}</p>
                <div class="flex items-center gap-3 text-xs text-gray-400">
                  <span>{post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  {post.data.readTime && <span>{post.data.readTime} min</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {/* Empty state */}
    {sortedPosts.length === 0 && (
      <div class="text-center py-16">
        <div class="text-5xl mb-4" aria-hidden="true">📝</div>
        <h2 class="text-xl font-bold font-heading mb-2" style="color: #1B2A4A;">Coming Soon</h2>
        <p class="text-gray-600">Our team is preparing expert articles on NJ tax and accounting topics. Check back soon!</p>
      </div>
    )}
  </div>

  <CTASection
    heading="Have a Tax Question Not Covered in Our Blog?"
    subheading="Schedule a free consultation with our Bergen County CPA team for personalized guidance on your specific situation."
    variant="dark"
  />
</BaseLayout>
