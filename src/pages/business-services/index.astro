---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/ui/CTASection.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';

const title = "Business Accounting Services NJ | ProAxis CPA | Bergen County";
const description = "ProAxis CPA provides full-service business accounting for NJ companies — bookkeeping, payroll, financial statements, fractional CFO, startup advisory, and financial technology consulting in Bergen County and beyond.";
const canonical = "/business-services/";
const breadcrumbs = [{ name: "Business Services" }];

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Business Accounting Services",
  "provider": {
    "@type": "AccountingService",
    "name": "ProAxis Tax & Accounting Services",
    "url": "https://proaxiscpa.com",
    "telephone": "(201) 800-2330",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Hasbrouck Heights",
      "addressRegion": "NJ",
      "postalCode": "07604"
    }
  },
  "areaServed": "New Jersey",
  "description": "Business accounting, bookkeeping, payroll, financial statements, fractional CFO, startup advisory, and financial technology consulting for NJ businesses."
};

const services = [
  {
    name: "Bookkeeping & Outsourced Accounting",
    slug: "bookkeeping",
    description: "CPA-supervised bookkeeping with QuickBooks Online — monthly reconciliation, financial reporting, and clean books that support better tax outcomes.",
    icon: "📒"
  },
  {
    name: "Fractional CFO Services",
    slug: "fractional-cfo",
    description: "Strategic financial leadership for growing NJ businesses — cash flow forecasting, KPI dashboards, budget analysis, and financing preparation without the cost of a full-time CFO.",
    icon: "📊"
  },
  {
    name: "Payroll Services",
    slug: "payroll",
    description: "Accurate, on-time, compliant payroll for NJ employers — covering federal and NJ-specific withholding requirements including UI, SDI, and FLI.",
    icon: "💼"
  },
  {
    name: "Financial Statements",
    slug: "financial-statements",
    description: "CPA-prepared compiled financial statements for lenders, investors, and internal management — balance sheet, income statement, and cash flow reporting.",
    icon: "📋"
  },
  {
    name: "Startup & New Business Advisory",
    slug: "startup-advisory",
    description: "Entity selection, accounting setup, EIN registration, initial tax elections, and first-year financial planning for NJ startups and new business owners.",
    icon: "🚀"
  },
  {
    name: "Financial Technology Consulting",
    slug: "financial-technology",
    description: "QuickBooks Online implementation, accounting automation, internal controls, and technology stack recommendations tailored to your business size and industry.",
    icon: "💻"
  }
];
---

<BaseLayout {title} {description} {canonical} {schema} {breadcrumbs}>
  <Breadcrumbs items={breadcrumbs} />

  <!-- Hero - navy gradient -->
  <section style="background: linear-gradient(135deg, #1C1C1E 0%, #2E75B6 100%);" class="py-14 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-heading text-white mb-4">
        Business Accounting &amp; Advisory Services for NJ Companies
      </h1>
      <p class="text-lg text-gray-300 mb-8 max-w-2xl">
        From day-to-day bookkeeping to strategic financial planning, ProAxis CPA delivers the accounting infrastructure NJ businesses need to grow with confidence.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/contact/" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-lg font-semibold text-white" style="background-color: #22C55E;">
          Schedule Free Consultation
        </a>
        <a href="tel:+12018002330" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-lg font-semibold text-white border-2 border-white/40">
          Call (201) 800-2330
        </a>
      </div>
    </div>
  </section>

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">

    <!-- Intro -->
    <section class="mb-12" aria-labelledby="overview">
      <h2 id="overview" class="text-2xl font-bold font-heading mb-4" style="color: #1C1C1E;">
        Full-Service Business Accounting Under One Roof
      </h2>
      <p class="text-gray-700 leading-relaxed mb-4">
        Running a business in New Jersey demands more than just keeping receipts in order. Between federal tax obligations, NJ-specific payroll requirements, lender reporting needs, and the day-to-day pressures of managing cash flow, most business owners find themselves stretched thin — often relying on disconnected software, part-time help, or doing it themselves. That patchwork approach costs money, creates compliance risk, and leaves real tax savings on the table.
      </p>
      <p class="text-gray-700 leading-relaxed mb-4">
        ProAxis Tax &amp; Accounting Services was built specifically to serve small and mid-sized businesses in Bergen County and across New Jersey. We operate as a fully virtual firm, which means our clients get CPA-level expertise without geographic limitations and without the overhead of an in-house finance department. Whether you are a solo professional who has outgrown spreadsheets or a $5M company preparing for a bank line of credit, we have the depth and the systems to support you.
      </p>
      <p class="text-gray-700 leading-relaxed mb-4">
        Our business services are designed to work together. Clean books from our bookkeeping team feed directly into accurate financial statements. Accurate financial statements support better tax planning. Better tax planning connects back to payroll structure and entity strategy. Every service we offer is integrated by design — not bolted together from separate vendors.
      </p>
      <p class="text-gray-700 leading-relaxed">
        Below is an overview of our six core business accounting service lines. Each page goes deeper into what is included, who it is right for, and how our approach differs from generic bookkeeping firms or payroll-only providers.
      </p>
    </section>

    <!-- Service Cards -->
    <section class="mb-12" aria-labelledby="services-list">
      <h2 id="services-list" class="text-2xl font-bold font-heading mb-6" style="color: #1C1C1E;">
        Our Business Services
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {services.map((service) => (
          <a
            href={`/business-services/${service.slug}/`}
            class="block p-6 rounded-xl border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all group"
          >
            <div class="text-3xl mb-3">{service.icon}</div>
            <h3 class="text-lg font-bold font-heading mb-2 group-hover:text-blue-700 transition-colors" style="color: #1C1C1E;">
              {service.name}
            </h3>
            <p class="text-gray-600 text-sm leading-relaxed">{service.description}</p>
            <span class="inline-block mt-3 text-sm font-semibold" style="color: #2E75B6;">Learn more →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Why ProAxis -->
    <section class="mb-12 rounded-xl p-8" style="background-color: #F7F8FA;" aria-labelledby="why-proaxis">
      <h2 id="why-proaxis" class="text-2xl font-bold font-heading mb-4" style="color: #1C1C1E;">
        Why NJ Businesses Choose ProAxis
      </h2>
      <p class="text-gray-700 leading-relaxed mb-4">
        Many accounting firms in New Jersey take a compliance-only approach: they show up at tax time, file your return, and disappear until next year. ProAxis operates differently. We stay engaged with your business throughout the year, which means we catch problems early, identify planning opportunities before deadlines pass, and give you financial data you can actually use to make decisions.
      </p>
      <ul class="space-y-3 text-gray-700">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-5 w-5 flex-shrink-0 rounded-full flex items-center justify-center text-white text-xs font-bold" style="background-color: #22C55E;">✓</span>
          <span><strong class="font-semibold">CPA-supervised work product</strong> — every deliverable reviewed by a licensed CPA, not outsourced to uncertified staff</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-5 w-5 flex-shrink-0 rounded-full flex items-center justify-center text-white text-xs font-bold" style="background-color: #22C55E;">✓</span>
          <span><strong class="font-semibold">Cloud-native and fully virtual</strong> — no office visits required, real-time access to your books and reports from anywhere</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-5 w-5 flex-shrink-0 rounded-full flex items-center justify-center text-white text-xs font-bold" style="background-color: #22C55E;">✓</span>
          <span><strong class="font-semibold">NJ-specific expertise</strong> — fluent in New Jersey's unique payroll tax structure, entity considerations, and business tax requirements</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-5 w-5 flex-shrink-0 rounded-full flex items-center justify-center text-white text-xs font-bold" style="background-color: #22C55E;">✓</span>
          <span><strong class="font-semibold">Integrated service delivery</strong> — bookkeeping, tax, payroll, and advisory handled under one roof so nothing falls through the cracks</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-5 w-5 flex-shrink-0 rounded-full flex items-center justify-center text-white text-xs font-bold" style="background-color: #22C55E;">✓</span>
          <span><strong class="font-semibold">Right-sized for small and mid-market businesses</strong> — our engagements are built for companies from startup stage through $10M in revenue</span>
        </li>
      </ul>
    </section>

    <!-- Who We Serve -->
    <section class="mb-12" aria-labelledby="who-we-serve">
      <h2 id="who-we-serve" class="text-2xl font-bold font-heading mb-4" style="color: #1C1C1E;">
        Industries and Business Types We Serve
      </h2>
      <p class="text-gray-700 leading-relaxed mb-4">
        ProAxis works with a broad range of New Jersey businesses across Bergen County and the surrounding region. Our clients include professional service firms — attorneys, consultants, architects, and healthcare providers — as well as contractors, retailers, real estate investors, technology companies, and service businesses at every stage of growth.
      </p>
      <p class="text-gray-700 leading-relaxed mb-4">
        We have particular depth serving businesses that are transitioning from startup to established operations, companies preparing for a line of credit or SBA loan, and owner-operated businesses where the owner wants better financial visibility without hiring a full-time controller. If your business is generating revenue and you feel like your accounting has not kept pace with your growth, that is exactly the situation we are built for.
      </p>
      <p class="text-gray-700 leading-relaxed">
        Not sure which service is right for you? Start with a free 30-minute consultation. We will assess your current situation and recommend only what your business actually needs — not a package designed to maximize our billing.
      </p>
    </section>

    <!-- CTA Banner -->
    <div class="my-10 rounded-xl p-6 text-white" style="background-color: #1C1C1E;">
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="flex-1">
          <h3 class="font-bold font-heading text-lg mb-1">Ready to get started?</h3>
          <p class="text-gray-300 text-sm">Schedule a free 30-minute consultation with our team.</p>
        </div>
        <a href="/contact/" class="flex-shrink-0 px-6 py-3 rounded-lg font-semibold text-white" style="background-color: #22C55E;">Book Free Call</a>
      </div>
    </div>

  </article>

  <TestimonialsSection />
  <CTASection heading="Ready to put your business finances on solid ground?" />
</BaseLayout>
