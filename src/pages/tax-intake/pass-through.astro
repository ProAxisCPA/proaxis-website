                    <label class="intake-label sm:sr-only" for={`dist${n}-cash`}>Cash</label>
                    <div class="relative">
                      <span class="dollar-prefix">$</span>
                      <input class="intake-input intake-dollar" type="text" id={`dist${n}-cash`} name={`dist${n}_cash`} placeholder="0.00" inputmode="decimal" />
