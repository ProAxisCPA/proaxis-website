  /* Toggle buttons */
  .intake-toggle-option { cursor: pointer; }
  .intake-toggle-btn { display: inline-block; padding: 0.5rem 1.25rem; border-radius: 0.5rem; border: 1.5px solid #DCDCE0; background-color: white; font-size: 0.875rem; font-weight: 500; color: #1C1C1E; transition: all 0.15s; user-select: none; }
  .intake-toggle-option:has(input:checked) .intake-toggle-btn { background-color: #1C1C1E; border-color: #1C1C1E; color: #E5E4E2; }
</style>
