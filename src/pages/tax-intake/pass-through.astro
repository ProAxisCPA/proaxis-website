            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Loans -->
          <fieldset>
            <legend class="intake-legend">Shareholder / Partner Loans</legend>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="loans-from-entity">Loans FROM Entity to Owners (outstanding balance)</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="loans-from-entity" name="loans_from_entity_to_owners" placeholder="0.00" inputmode="decimal" />
