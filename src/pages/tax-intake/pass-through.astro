                      <span class="dollar-prefix">$</span>
                      <input class="intake-input intake-dollar" type="text" id={`dist${n}-prop`} name={`dist${n}_property`} placeholder="0.00" inputmode="decimal" />
                    </div>
                  </div>
                </div>
