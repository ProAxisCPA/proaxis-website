                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="dist-property-total" name="distributions_property_total" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Per-owner distributions -->
          <fieldset>
            <legend class="intake-legend">Per-Owner Distributions</legend>
            <div class="hidden sm:grid dist-grid gap-2 mb-2 px-1">
              <p class="col-span-4 text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Owner Name</p>
              <p class="col-span-4 text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Cash Distributions ($)</p>
              <p class="col-span-4 text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Property Distributions ($)</p>
            </div>
            <div class="space-y-3">
              {[1,2,3,4].map(n => (
                <div class="rounded-xl p-3 sm:p-0 sm:rounded-none grid grid-cols-1 sm:dist-grid sm:border-0 gap-3 sm:gap-2 items-center dist-row" style="background-color: #EEEEF2; border: 1px solid #DCDCE0;">
                  <div class="sm:col-span-4">
                    <label class="intake-label sm:sr-only" for={`dist${n}-name`}>Owner {n}</label>
                    <input class="intake-input" type="text" id={`dist${n}-name`} name={`dist${n}_owner_full_name`} placeholder="As it appears on their Social Security card or ID" />
