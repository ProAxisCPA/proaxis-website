---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Pass-Through Entity Tax Intake (S-Corp & Partnership) | ProAxis CPA";
const description = "Complete your pass-through entity tax intake for ProAxis Tax & Accounting Services. S-Corporations (Form 1120-S) and Partnerships (Form 1065) — provide the details we need to prepare your return, issue K-1s, and plan your NJ BAIT election.";
const canonical = "/tax-intake/pass-through/";
---

<BaseLayout {title} {description} {canonical} noindex={true}>

  <!-- Page Header -->
  <section style="background: linear-gradient(135deg, #1C1C1E 0%, #2a2a2e 100%);" class="py-14 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: #C5A55A;">ProAxis Tax & Accounting Services</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-heading text-white mb-4">
        Pass-Through Entity Tax Intake
      </h1>
      <div class="flex items-center justify-center gap-3 flex-wrap mb-5">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold" style="background-color: rgba(197,165,90,0.15); color: #C5A55A; border: 1px solid rgba(197,165,90,0.3);">Form 1120-S — S-Corporation</span>
        <span class="text-white/30 text-sm">•</span>
        <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold" style="background-color: rgba(46,117,182,0.15); color: #7BB8F0; border: 1px solid rgba(46,117,182,0.3);">Form 1065 — Partnership / LLC</span>
      </div>
      <p class="text-base sm:text-lg leading-relaxed max-w-2xl mx-auto" style="color: #A0A0A8;">
        Complete this intake so our CPA team can prepare your entity return, generate accurate K-1s for each owner, and evaluate the NJ BAIT election that may reduce your owners' federal tax liability.
        Provide the <strong class="text-white">last 4 digits</strong> of EINs and SSNs only.
      </p>
    </div>
  </section>

  <!-- Form -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <form
      data-netlify="true"
      name="pass-through-intake"
      method="POST"
      action="/tax-intake/success/"
      netlify-honeypot="bot-field"
      class="space-y-8"
      id="pt-intake-form"
    >
      <input type="hidden" name="form-name" value="pass-through-intake" />
      <input type="hidden" name="subject" id="form-subject" value="New Pass-Through Submission" />

      <!-- Honeypot -->
      <p class="hidden" aria-hidden="true">
        <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
      </p>

      <!-- ─────────────────────────────────────────────
           SECTION 1 · ENTITY DETAILS
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Entity Details</h2>
          <p class="intake-card-sub">Legal entity information, election dates, tax year, and primary contact</p>
        </div>
        <div class="intake-card-body space-y-6">

          <!-- Entity Type Selection -->
          <fieldset>
            <legend class="intake-legend">Entity Type</legend>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {[
                { value: "s_corp", label: "S-Corporation", sub: "Form 1120-S" },
                { value: "partnership", label: "Partnership", sub: "Form 1065" },
                { value: "llc_partnership", label: "LLC — Taxed as Partnership", sub: "Form 1065" },
                { value: "llc_s_corp", label: "LLC — Taxed as S-Corporation", sub: "Form 1120-S" },
                { value: "llp", label: "Limited Liability Partnership (LLP)", sub: "Form 1065" },
                { value: "lp", label: "Limited Partnership (LP)", sub: "Form 1065" },
              ].map(opt => (
                <label class="intake-radio-card w-full gap-3">
                  <input type="radio" name="entity_type" value={opt.value} class="sr-only" />
                  <span class="intake-radio-dot flex-shrink-0"></span>
                  <span>
                    <span class="block text-sm font-semibold" style="color: #1C1C1E;">{opt.label}</span>
                    <span class="block text-xs" style="color: #6B7280;">{opt.sub}</span>
                  </span>
                </label>
              ))}
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Entity Identity -->
          <fieldset>
            <legend class="intake-legend">Entity Information</legend>
            <div class="intake-grid">
              <div class="sm:col-span-2">
                <label class="intake-label" for="entity-name">Legal Entity Name</label>
                <input class="intake-input" type="text" id="entity-name" name="entity_name" placeholder="As filed with the state / IRS" />
              </div>
              <div>
                <label class="intake-label" for="entity-ein">EIN (Last 4 digits only)</label>
                <input class="intake-input" type="text" id="entity-ein" name="entity_ein_last4" placeholder="XXXX" maxlength="4" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label" for="state-formation">State of Formation</label>
                <select class="intake-input" id="state-formation" name="state_of_formation">
                  <option value="">Select...</option>
                  <option value="NJ" selected>New Jersey</option>
                  <option value="NY">New York</option>
                  <option value="DE">Delaware</option>
                  <option value="CT">Connecticut</option>
                  <option value="PA">Pennsylvania</option>
                  <option value="FL">Florida</option>
                  <option value="TX">Texas</option>
                  <option value="CA">California</option>
                  <option value="OTHER">Other</option>
                </select>
              </div>
              <div>
                <label class="intake-label" for="state-operations">Principal State of Operations</label>
                <select class="intake-input" id="state-operations" name="state_of_operations">
                  <option value="">Select...</option>
                  <option value="NJ" selected>New Jersey</option>
                  <option value="NY">New York</option>
                  <option value="CT">Connecticut</option>
                  <option value="PA">Pennsylvania</option>
                  <option value="DE">Delaware</option>
                  <option value="OTHER">Other</option>
                </select>
              </div>
              <div>
                <label class="intake-label" for="date-formation">Date of Formation / Organization</label>
                <input class="intake-input" type="date" id="date-formation" name="date_of_formation" />
              </div>
              <div>
                <label class="intake-label" for="business-activity">Principal Business Activity</label>
                <input class="intake-input" type="text" id="business-activity" name="business_activity" placeholder="e.g. Medical practice, Real estate, IT consulting" />
              </div>
              <div>
                <label class="intake-label" for="naics-code">NAICS / Business Code</label>
                <input class="intake-input" type="text" id="naics-code" name="naics_code" placeholder="e.g. 541511" />
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- S-Election Details (S-Corps only) -->
          <fieldset>
            <legend class="intake-legend">S-Corporation Election <span class="legend-optional">(S-Corps only — skip if partnership)</span></legend>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="s-election-date">Date of S-Election (Form 2553)</label>
                <input class="intake-input" type="date" id="s-election-date" name="s_election_date" />
              </div>
              <div>
                <label class="intake-label" for="s-election-effective">Effective Date of S-Election</label>
                <input class="intake-input" type="date" id="s-election-effective" name="s_election_effective_date" />
              </div>
              <div class="sm:col-span-2">
                <p class="text-sm font-semibold mb-2" style="color: #1C1C1E;">Was the entity previously a C-Corporation before the S-Election?</p>
                <div class="flex gap-3 flex-wrap">
                  {["Yes", "No", "N/A — Always been an S-Corp"].map(opt => (
                    <label class="intake-toggle-option">
                      <input type="radio" name="prior_c_corp" value={opt} class="sr-only" />
                      <span class="intake-toggle-btn">{opt}</span>
                    </label>
                  ))}
                </div>
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Tax Year & Accounting -->
          <fieldset>
            <legend class="intake-legend">Tax Year & Accounting Method</legend>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="tax-year-begin">Tax Year Beginning</label>
                <input class="intake-input" type="date" id="tax-year-begin" name="tax_year_begin" />
              </div>
              <div>
                <label class="intake-label" for="tax-year-end">Tax Year Ending</label>
                <input class="intake-input" type="date" id="tax-year-end" name="tax_year_end" />
              </div>
              <div>
                <label class="intake-label" for="accounting-method">Accounting Method</label>
                <select class="intake-input" id="accounting-method" name="accounting_method">
                  <option value="">Select...</option>
                  <option value="cash">Cash Basis</option>
                  <option value="accrual">Accrual Basis</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label class="intake-label" for="return-type">Return Type</label>
                <select class="intake-input" id="return-type" name="return_type">
                  <option value="">Select...</option>
                  <option value="ongoing">Ongoing — regular annual return</option>
                  <option value="initial">Initial Return — first year filing</option>
                  <option value="final">Final Return — entity dissolving</option>
                  <option value="amended">Amended Return</option>
                </select>
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Entity Address & Primary Contact -->
          <fieldset>
            <legend class="intake-legend">Principal Office Address</legend>
            <div class="intake-grid">
              <div class="sm:col-span-2">
                <label class="intake-label" for="entity-street">Street Address</label>
                <input class="intake-input" type="text" id="entity-street" name="entity_address_street" placeholder="123 Business Ave, Suite 100" />
              </div>
              <div>
                <label class="intake-label" for="entity-city">City</label>
                <input class="intake-input" type="text" id="entity-city" name="entity_address_city" />
              </div>
              <div>
                <label class="intake-label" for="entity-state">State</label>
                <select class="intake-input" id="entity-state" name="entity_address_state">
                  <option value="">Select...</option>
                  <option value="NJ" selected>New Jersey</option>
                  <option value="NY">New York</option>
                  <option value="CT">Connecticut</option>
                  <option value="PA">Pennsylvania</option>
                  <option value="OTHER">Other</option>
                </select>
              </div>
              <div>
                <label class="intake-label" for="entity-zip">ZIP Code</label>
                <input class="intake-input" type="text" id="entity-zip" name="entity_address_zip" placeholder="07604" maxlength="10" inputmode="numeric" />
              </div>
            </div>
          </fieldset>

          <fieldset class="mt-4">
            <legend class="intake-legend">Primary Contact</legend>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="contact-name">Full Legal Name & Title</label>
                <input class="intake-input" type="text" id="contact-name" name="contact_full_name_title" placeholder="As it appears on your Social Security card or ID — e.g. Jane A. Smith, Managing Partner" />
              </div>
              <div>
                <label class="intake-label" for="contact-email">Email Address</label>
                <input class="intake-input" type="email" id="contact-email" name="contact_email" placeholder="contact@entity.com" />
              </div>
              <div>
                <label class="intake-label" for="contact-phone">Phone Number</label>
                <input class="intake-input" type="tel" id="contact-phone" name="contact_phone" placeholder="(201) 000-0000" />
              </div>
            </div>
          </fieldset>

        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 2 · OWNERSHIP / PARTNERS / SHAREHOLDERS
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Ownership — Partners & Shareholders</h2>
          <p class="intake-card-sub">List every owner — this drives K-1 generation. Ownership percentages must total 100%.</p>
        </div>
        <div class="intake-card-body space-y-5">

          <!-- Column headers (desktop) -->
          <div class="hidden sm:grid owner-grid gap-2 px-1">
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Full Name</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">SSN / EIN (Last 4)</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Ownership %</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Role / Title</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Resident State</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Entity / Individual</p>
          </div>

          {[1,2,3,4,5,6].map(n => (
            <div class="rounded-xl p-4 sm:p-0 sm:rounded-none grid grid-cols-1 sm:owner-grid gap-3 sm:gap-2 items-end owner-row" style="background-color: #EEEEF2; border: 1px solid #DCDCE0;">
              <div>
                <label class="intake-label sm:sr-only" for={`own${n}-name`}>Owner {n} Full Legal Name</label>
                <input class="intake-input" type="text" id={`own${n}-name`} name={`owner${n}_full_name`} placeholder="As it appears on SSN card or ID" />
              </div>
              <div>
                <label class="intake-label sm:sr-only" for={`own${n}-ssn`}>SSN / EIN Last 4</label>
                <input class="intake-input" type="text" id={`own${n}-ssn`} name={`owner${n}_id_last4`} placeholder="XXXX" maxlength="4" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label sm:sr-only" for={`own${n}-pct`}>Ownership %</label>
                <div class="relative">
                  <input class="intake-input pr-8" type="number" id={`own${n}-pct`} name={`owner${n}_ownership_pct`} placeholder="0" min="0" max="100" step="0.01" inputmode="decimal" />
                  <span class="pct-suffix">%</span>
                </div>
              </div>
              <div>
                <label class="intake-label sm:sr-only" for={`own${n}-role`}>Role</label>
                <input class="intake-input" type="text" id={`own${n}-role`} name={`owner${n}_role`} placeholder="Partner, President, Member..." />
              </div>
              <div>
                <label class="intake-label sm:sr-only" for={`own${n}-state`}>Resident State</label>
                <select class="intake-input" id={`own${n}-state`} name={`owner${n}_resident_state`}>
                  <option value="">State...</option>
                  <option value="NJ">NJ</option>
                  <option value="NY">NY</option>
                  <option value="CT">CT</option>
                  <option value="PA">PA</option>
                  <option value="DE">DE</option>
                  <option value="FL">FL</option>
                  <option value="TX">TX</option>
                  <option value="CA">CA</option>
                  <option value="OTHER">Other</option>
                </select>
              </div>
              <div>
                <label class="intake-label sm:sr-only" for={`own${n}-type`}>Individual or Entity</label>
                <select class="intake-input" id={`own${n}-type`} name={`owner${n}_owner_type`}>
                  <option value="">Type...</option>
                  <option value="individual">Individual</option>
                  <option value="trust">Trust</option>
                  <option value="corporation">Corporation</option>
                  <option value="partnership">Partnership / LLC</option>
                  <option value="ira">IRA / Retirement Account</option>
                </select>
              </div>
            </div>
          ))}

          <p class="text-xs" style="color: #6B7280;">More than 6 owners? List additional partners/shareholders in the Additional Notes section at the bottom.</p>

          <hr class="intake-divider" />

          <!-- Officer W-2 Compensation (S-Corps) -->
          <fieldset>
            <legend class="intake-legend">Officer W-2 Compensation <span class="legend-optional">(S-Corporations only)</span></legend>
            <p class="text-xs mb-4" style="color: #6B7280;">
              S-Corp owner-operators must receive reasonable W-2 compensation. List the W-2 wages paid to each shareholder-employee during the year.
            </p>
            <div class="space-y-3">
              {[1,2,3].map(n => (
                <div class="rounded-xl p-3 grid grid-cols-1 sm:grid-cols-3 gap-3 items-end" style="background-color: #EEEEF2; border: 1px solid #DCDCE0;">
                  <div>
                    <label class="intake-label" for={`off${n}-name`}>Full Legal Name</label>
                    <input class="intake-input" type="text" id={`off${n}-name`} name={`officer${n}_full_name`} placeholder="As it appears on their Social Security card or ID" />
                  </div>
                  <div>
                    <label class="intake-label" for={`off${n}-w2`}>W-2 Wages Paid</label>
                    <div class="relative">
                      <span class="dollar-prefix">$</span>
                      <input class="intake-input intake-dollar" type="text" id={`off${n}-w2`} name={`officer${n}_w2_wages`} placeholder="0.00" inputmode="decimal" />
                    </div>
                  </div>
                  <div>
                    <label class="intake-label" for={`off${n}-health`}>Health Insurance Premium (officer)</label>
                    <div class="relative">
                      <span class="dollar-prefix">$</span>
                      <input class="intake-input intake-dollar" type="text" id={`off${n}-health`} name={`officer${n}_health_insurance`} placeholder="0.00" inputmode="decimal" />
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- NJ BAIT -->
          <fieldset>
            <legend class="intake-legend">NJ Business Alternative Income Tax (BAIT)</legend>
            <p class="text-xs mb-4" style="color: #6B7280;">
              The NJ BAIT election allows pass-through entities to pay NJ income tax at the entity level, generating a fully deductible federal business expense that bypasses the $10,000 SALT cap for owners. It is one of the most powerful tax planning tools available to NJ pass-through entity owners.
            </p>
            <div class="space-y-3">
              <div>
                <p class="text-sm font-semibold mb-2" style="color: #1C1C1E;">Did the entity make the NJ BAIT election for this tax year?</p>
                <div class="flex gap-3 flex-wrap">
                  {["Yes — BAIT elected", "No — not elected", "Not Sure / Ask CPA"].map(opt => (
                    <label class="intake-toggle-option">
                      <input type="radio" name="nj_bait_election" value={opt} class="sr-only" />
                      <span class="intake-toggle-btn">{opt}</span>
                    </label>
                  ))}
                </div>
              </div>
              <div class="intake-grid mt-3">
                <div>
                  <label class="intake-label" for="bait-estimated">BAIT Estimated Payments Made</label>
                  <div class="relative">
                    <span class="dollar-prefix">$</span>
                    <input class="intake-input intake-dollar" type="text" id="bait-estimated" name="nj_bait_estimated_payments" placeholder="0.00" inputmode="decimal" />
                  </div>
                </div>
                <div>
                  <label class="intake-label" for="bait-prior-credit">Prior Year BAIT Credit Carryforward</label>
                  <div class="relative">
                    <span class="dollar-prefix">$</span>
                    <input class="intake-input intake-dollar" type="text" id="bait-prior-credit" name="nj_bait_prior_credit" placeholder="0.00" inputmode="decimal" />
                  </div>
                </div>
              </div>
            </div>
          </fieldset>

        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 3 · FINANCIALS
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Financial Summary</h2>
          <p class="intake-card-sub">Gross receipts, cost of goods, and operating expenses for the tax year. Estimates are fine — your CPA reconciles from your books.</p>
        </div>
        <div class="intake-card-body space-y-6">

          <!-- Revenue -->
          <fieldset>
            <legend class="intake-legend">Revenue</legend>
            <div class="intake-grid">
              {[
                { name: "fin_gross_receipts", label: "Gross Receipts or Sales" },
                { name: "fin_returns_allowances", label: "Less: Returns & Allowances" },
                { name: "fin_cost_goods_sold", label: "Cost of Goods Sold (COGS)" },
                { name: "fin_other_income", label: "Other Income (interest, rents, gains)" },
              ].map(item => (
                <div>
                  <label class="intake-label" for={item.name}>{item.label}</label>
                  <div class="relative">
                    <span class="dollar-prefix">$</span>
                    <input class="intake-input intake-dollar" type="text" id={item.name} name={item.name} placeholder="0.00" inputmode="decimal" />
                  </div>
                </div>
              ))}
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Operating Expenses -->
          <fieldset>
            <legend class="intake-legend">Operating Expenses</legend>
            <div class="intake-grid">
              {[
                { name: "exp_compensation_officers", label: "Compensation of Officers / Managing Members" },
                { name: "exp_salaries_wages", label: "Salaries & Wages (non-officer)" },
                { name: "exp_repairs_maintenance", label: "Repairs & Maintenance" },
                { name: "exp_rents", label: "Rents Paid" },
                { name: "exp_taxes_licenses", label: "Taxes & Licenses" },
                { name: "exp_interest", label: "Interest Expense" },
                { name: "exp_depreciation", label: "Depreciation (Form 4562)" },
                { name: "exp_advertising", label: "Advertising & Marketing" },
                { name: "exp_pension_profit_sharing", label: "Pension / Profit-Sharing Plans" },
                { name: "exp_employee_benefits", label: "Employee Benefit Programs" },
                { name: "exp_legal_professional", label: "Legal & Professional Fees" },
                { name: "exp_meals_travel", label: "Meals (50%) & Travel" },
                { name: "exp_contract_labor", label: "Contract Labor / 1099 Workers" },
                { name: "exp_insurance", label: "Business Insurance" },
                { name: "exp_utilities_office", label: "Utilities & Office Supplies" },
                { name: "exp_other", label: "Other Deductions" },
              ].map(item => (
                <div>
                  <label class="intake-label" for={item.name}>{item.label}</label>
                  <div class="relative">
                    <span class="dollar-prefix">$</span>
                    <input class="intake-input intake-dollar" type="text" id={item.name} name={item.name} placeholder="0.00" inputmode="decimal" />
                  </div>
                </div>
              ))}
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Separately Stated Items -->
          <fieldset>
            <legend class="intake-legend">Separately Stated Items <span class="legend-optional">(reported directly on owners' K-1s)</span></legend>
            <p class="text-xs mb-4" style="color: #6B7280;">These items are not combined into ordinary income — they flow separately to each owner's individual return and retain their character.</p>
            <div class="intake-grid">
              {[
                { name: "sep_interest_income", label: "Interest Income" },
                { name: "sep_dividend_income", label: "Ordinary & Qualified Dividends" },
                { name: "sep_capital_gain_short", label: "Short-Term Capital Gains / Losses" },
                { name: "sep_capital_gain_long", label: "Long-Term Capital Gains / Losses" },
                { name: "sep_section_1231", label: "§1231 Gains / Losses (Form 4797)" },
                { name: "sep_charitable_contributions", label: "Charitable Contributions" },
                { name: "sep_foreign_taxes", label: "Foreign Taxes Paid" },
                { name: "sep_section_179", label: "Section 179 Deduction" },
                { name: "sep_rental_income", label: "Net Rental Real Estate Income / Loss" },
                { name: "sep_other_rental", label: "Other Net Rental Income / Loss" },
              ].map(item => (
                <div>
                  <label class="intake-label" for={item.name}>{item.label}</label>
                  <div class="relative">
                    <span class="dollar-prefix">$</span>
                    <input class="intake-input intake-dollar" type="text" id={item.name} name={item.name} placeholder="0.00" inputmode="decimal" />
                  </div>
                </div>
              ))}
            </div>
          </fieldset>

          <div class="mt-2">
            <label class="intake-label" for="financials-notes">Financial Notes</label>
            <textarea class="intake-input" id="financials-notes" name="financials_notes" rows="3" placeholder="Intercompany transactions, significant one-time items, related-party rents or fees, or any context your CPA needs to understand the numbers..."></textarea>
          </div>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 4 · DISTRIBUTIONS
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Distributions & Owner Draws</h2>
          <p class="intake-card-sub">Cash and property distributions made to owners during the tax year — critical for basis tracking and K-1 accuracy</p>
        </div>
        <div class="intake-card-body space-y-5">

          <div class="rounded-xl p-5" style="background-color: #EEF3FA; border: 1px solid #C8D9EE;">
            <p class="text-sm font-semibold mb-1" style="color: #1C1C1E;">Why distributions matter</p>
            <p class="text-xs leading-relaxed" style="color: #4A6080;">
              For S-Corp shareholders, distributions in excess of basis are taxable as capital gains. For partners, distributions affect outside basis and may trigger gain recognition. Accurate distribution data is essential for correct K-1 reporting and basis schedule maintenance.
            </p>
          </div>

          <!-- Total distributions -->
          <fieldset>
            <legend class="intake-legend">Total Distributions — All Owners Combined</legend>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="dist-cash-total">Total Cash Distributions</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="dist-cash-total" name="distributions_cash_total" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
              <div>
                <label class="intake-label" for="dist-property-total">Total Property Distributions (FMV)</label>
