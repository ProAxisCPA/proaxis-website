        </div>
        <div class="intake-card-body space-y-6">

          <!-- Assets -->
          <fieldset>
            <legend class="intake-legend">Assets (End of Year)</legend>
            <div class="intake-grid">
              {[
                { name: "bs_cash_equivalents", label: "Cash & Cash Equivalents" },
                { name: "bs_accounts_receivable", label: "Accounts Receivable (net)" },
                { name: "bs_inventories", label: "Inventories" },
                { name: "bs_other_current_assets", label: "Other Current Assets" },
                { name: "bs_investments", label: "Investments & Securities" },
                { name: "bs_fixed_assets_net", label: "Fixed Assets — Net of Depreciation" },
                { name: "bs_loans_to_owners", label: "Loans to Shareholders / Partners" },
                { name: "bs_intangibles", label: "Intangible Assets (goodwill, IP) — net" },
                { name: "bs_other_assets", label: "Other Assets" },
              ].map(item => (
