---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Client Tax Intake Forms | ProAxis CPA Bergen County";
const description = "Select the right intake form for your tax situation. ProAxis Tax & Accounting Services offers digital intake forms for individuals, sole proprietors, S-Corps, partnerships, and C-Corporations.";
const canonical = "/tax-intake/";

const forms = [
  {
    href: "/tax-intake/individual/",
    form: "Form 1040",
    title: "Individual (1040)",
    description: "For individuals and households — W-2 earners, investors, rental income, retirement distributions, and all personal tax situations.",
    icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
  },
  {
    href: "/tax-intake/soleproprietorship/",
    form: "Schedule C",
    title: "Sole Proprietor (Sch C)",
    description: "For self-employed individuals, freelancers, and single-member LLC owners filing Schedule C with their personal return.",
    icon: "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  },
  {
    href: "/tax-intake/pass-through/",
    form: "Form 1120-S / 1065",
    title: "Pass-Through (S-Corp / Partnership)",
    description: "For S-Corporations, partnerships, multi-member LLCs, and other pass-through entities that issue K-1s to owners.",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
  },
  {
    href: "/tax-intake/corporate/",
    form: "Form 1120",
    title: "C-Corporation (1120)",
    description: "For C-Corporations filing Form 1120 — includes Schedule L balance sheet, officer compensation, R&D credits, and corporate deductions.",
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  },
];
---

<BaseLayout {title} {description} {canonical} noindex={true}>

  <!-- Header -->
  <section style="background: linear-gradient(135deg, #1C1C1E 0%, #2a2a2e 100%);" class="py-14 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: #C5A55A;">ProAxis Tax & Accounting Services</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-heading text-white mb-5">
        Client Tax Intake
      </h1>
      <p class="text-base sm:text-lg leading-relaxed max-w-2xl mx-auto" style="color: #A0A0A8;">
        Select the intake form that matches your tax situation. Each form is tailored to capture the specific information your CPA needs to prepare your return and identify every available deduction.
      </p>
    </div>
  </section>

  <!-- Form Cards -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {forms.map(f => (
        <a
          href={f.href}
          class="group block rounded-2xl overflow-hidden transition-all hover:shadow-xl hover:-translate-y-0.5"
          style="border: 1px solid #2E2E32;"
        >
          <div class="px-6 py-5" style="background-color: #1C1C1E;">
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs font-semibold uppercase tracking-widest" style="color: #C5A55A;">{f.form}</span>
              <svg class="w-5 h-5 opacity-40 group-hover:opacity-100 transition-opacity" style="color: #E5E4E2;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
            <h2 class="text-lg font-bold font-heading" style="color: #E5E4E2;">{f.title}</h2>
          </div>
          <div class="px-6 py-5" style="background-color: #F7F8FA;">
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #1C1C1E;">
                <svg class="w-5 h-5" style="color: #E5E4E2;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={f.icon} />
                </svg>
              </div>
              <p class="text-sm leading-relaxed" style="color: #4A4A52;">{f.description}</p>
            </div>
            <div class="mt-4 flex items-center gap-1 text-xs font-semibold" style="color: #2E75B6;">
              Start Intake
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-10 rounded-2xl px-6 py-6 text-center" style="background-color: #F7F8FA; border: 1px solid #E0E0E4;">
      <p class="text-sm mb-1 font-semibold" style="color: #1C1C1E;">Not sure which form to use?</p>
      <p class="text-sm mb-4" style="color: #6B7280;">Call us and we'll point you in the right direction — no obligation.</p>
      <a href="tel:+12018002330" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm transition-all hover:opacity-90" style="background-color: #1C1C1E; color: #E5E4E2;">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        (201) 800-2330
      </a>
    </div>
  </div>

</BaseLayout>
