---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Individual & Small Business Tax Intake | ProAxis CPA";
const description = "Complete your individual and small business tax strategy intake for ProAxis Tax & Accounting Services. Securely share the details we need to identify every deduction and make your consultation as productive as possible.";
const canonical = "/tax-intake/soleproprietorship/";

const expenseCategories = [
  { name: "exp_advertising", label: "Advertising & Marketing" },
  { name: "exp_car_truck", label: "Car & Truck Expenses" },
  { name: "exp_commissions", label: "Commissions & Fees" },
  { name: "exp_contract_labor", label: "Contract Labor (1099 workers)" },
  { name: "exp_depletion", label: "Depletion" },
  { name: "exp_depreciation", label: "Depreciation (Form 4562)" },
  { name: "exp_insurance", label: "Business Insurance" },
  { name: "exp_interest_mortgage", label: "Mortgage Interest (business property)" },
  { name: "exp_interest_other", label: "Other Business Interest" },
  { name: "exp_legal_professional", label: "Legal & Professional Fees" },
  { name: "exp_office", label: "Office Supplies & Expenses" },
  { name: "exp_pension_profit", label: "Pension / Profit-Sharing Plans" },
  { name: "exp_rent_lease_vehicle", label: "Rent / Lease — Vehicles & Equipment" },
  { name: "exp_rent_lease_property", label: "Rent / Lease — Business Property" },
  { name: "exp_repairs_maintenance", label: "Repairs & Maintenance" },
  { name: "exp_supplies", label: "Supplies" },
  { name: "exp_taxes_licenses", label: "Taxes & Licenses" },
  { name: "exp_travel", label: "Travel (airfare, hotels, etc.)" },
  { name: "exp_meals", label: "Meals (50% deductible)" },
  { name: "exp_utilities", label: "Utilities" },
  { name: "exp_wages", label: "Wages Paid to Employees" },
  { name: "exp_other", label: "Other Expenses (describe in notes)" },
];
---

<BaseLayout {title} {description} {canonical} noindex={true}>

  <!-- Page Header -->
  <section style="background: linear-gradient(135deg, #1C1C1E 0%, #2a2a2e 100%);" class="py-14 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: #C5A55A;">ProAxis Tax & Accounting Services</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-heading text-white mb-5">
        Individual & Small Business Tax Intake
      </h1>
      <p class="text-base sm:text-lg leading-relaxed max-w-2xl mx-auto" style="color: #A0A0A8;">
        This information allows us to identify every eligible deduction and make your consultation as productive as possible.
        Please provide the <strong class="text-white">last 4 digits</strong> of sensitive IDs only.
        Dollar amounts are estimates — exact figures are confirmed from your documents.
      </p>
    </div>
  </section>

  <!-- Form -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <form
      data-netlify="true"
      name="business-owner-intake"
      method="POST"
      action="/tax-intake/success/"
      netlify-honeypot="bot-field"
      class="space-y-8"
      id="sp-intake-form"
    >
      <input type="hidden" name="form-name" value="business-owner-intake" />
      <input type="hidden" name="subject" id="form-subject" value="New Business Intake Submission" />
      <p class="hidden" aria-hidden="true">
        <label>Don't fill this out if you're human: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
      </p>

      <!-- ─────────────────────────────────────────────
           SECTION 1 · PERSONAL IDENTITY
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Personal Identity</h2>
          <p class="intake-card-sub">Taxpayer & Spouse — contact info, address, filing status, and dependents</p>
        </div>
        <div class="intake-card-body space-y-6">

          <!-- Taxpayer -->
          <fieldset>
            <legend class="intake-legend">Taxpayer (Primary)</legend>
            <div class="intake-grid">
              <div class="sm:col-span-2">
                <label class="intake-label" for="tp-name">Full Legal Name</label>
                <input class="intake-input" type="text" id="tp-name" name="taxpayer_full_name" placeholder="As it appears on your Social Security card or ID" autocomplete="name" />
              </div>
              <div>
                <label class="intake-label" for="tp-dob">Date of Birth</label>
                <input class="intake-input" type="date" id="tp-dob" name="taxpayer_dob" />
              </div>
              <div>
                <label class="intake-label" for="tp-ssn">Last 4 of SSN / ITIN</label>
                <input class="intake-input" type="text" id="tp-ssn" name="taxpayer_ssn_last4" placeholder="XXXX" maxlength="4" pattern="\d{4}" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label" for="tp-email">Email Address</label>
                <input class="intake-input" type="email" id="tp-email" name="taxpayer_email" placeholder="you@example.com" autocomplete="email" />
              </div>
              <div>
                <label class="intake-label" for="tp-phone">Phone Number</label>
                <input class="intake-input" type="tel" id="tp-phone" name="taxpayer_phone" placeholder="(201) 000-0000" autocomplete="tel" />
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Spouse -->
          <fieldset>
            <legend class="intake-legend">Spouse / Partner <span class="legend-optional">(if applicable)</span></legend>
            <div class="intake-grid">
              <div class="sm:col-span-2">
                <label class="intake-label" for="sp-name">Full Legal Name</label>
                <input class="intake-input" type="text" id="sp-name" name="spouse_full_name" placeholder="As it appears on their Social Security card or ID" />
              </div>
              <div>
                <label class="intake-label" for="sp-dob">Date of Birth</label>
                <input class="intake-input" type="date" id="sp-dob" name="spouse_dob" />
              </div>
              <div>
                <label class="intake-label" for="sp-ssn">Last 4 of SSN / ITIN</label>
                <input class="intake-input" type="text" id="sp-ssn" name="spouse_ssn_last4" placeholder="XXXX" maxlength="4" pattern="\d{4}" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label" for="sp-occupation">Occupation</label>
                <input class="intake-input" type="text" id="sp-occupation" name="spouse_occupation" />
              </div>
              <div>
                <label class="intake-label" for="sp-employer">Employer</label>
                <input class="intake-input" type="text" id="sp-employer" name="spouse_employer" />
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Address -->
          <fieldset>
            <legend class="intake-legend">Home Address</legend>
            <div class="intake-grid">
              <div class="sm:col-span-2">
                <label class="intake-label" for="addr-street">Street Address</label>
                <input class="intake-input" type="text" id="addr-street" name="home_address_street" placeholder="123 Main Street" autocomplete="street-address" />
              </div>
              <div>
                <label class="intake-label" for="addr-city">City</label>
                <input class="intake-input" type="text" id="addr-city" name="home_address_city" placeholder="Hasbrouck Heights" />
              </div>
              <div>
                <label class="intake-label" for="addr-state">State</label>
                <select class="intake-input" id="addr-state" name="home_address_state">
                  <option value="">Select...</option>
                  <option value="NJ" selected>New Jersey</option>
                  <option value="NY">New York</option>
                  <option value="CT">Connecticut</option>
                  <option value="PA">Pennsylvania</option>
                  <option value="DE">Delaware</option>
                  <option value="CA">California</option>
                  <option value="FL">Florida</option>
                  <option value="TX">Texas</option>
                  <option value="OTHER">Other</option>
                </select>
              </div>
              <div>
                <label class="intake-label" for="addr-zip">ZIP Code</label>
                <input class="intake-input" type="text" id="addr-zip" name="home_address_zip" placeholder="07604" maxlength="10" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label" for="addr-county">County</label>
                <input class="intake-input" type="text" id="addr-county" name="home_address_county" placeholder="Bergen" />
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Filing Status -->
          <fieldset>
            <legend class="intake-legend">Filing Status</legend>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-1">
              {[
                { value: "single", label: "Single" },
                { value: "mfj", label: "Married Filing Jointly (MFJ)" },
                { value: "mfs", label: "Married Filing Separately (MFS)" },
                { value: "hoh", label: "Head of Household (HOH)" },
                { value: "qss", label: "Qualifying Surviving Spouse" },
              ].map(opt => (
                <label class="intake-radio-card">
                  <input type="radio" name="filing_status" value={opt.value} class="sr-only" />
                  <span class="intake-radio-dot"></span>
                  <span class="text-sm font-medium" style="color: #1C1C1E;">{opt.label}</span>
                </label>
              ))}
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Dependents — compact table -->
          <fieldset>
            <legend class="intake-legend">Dependents <span class="legend-optional">(list all you are claiming)</span></legend>
            <div class="hidden sm:grid dep-table-grid gap-2 mb-2 px-1">
              <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Full Legal Name</p>
              <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Date of Birth</p>
              <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">SSN Last 4</p>
              <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Relationship</p>
            </div>
            <div class="space-y-2">
              {[1, 2, 3, 4].map(n => (
                <div class="rounded-xl p-3 sm:p-0 sm:rounded-none grid grid-cols-1 sm:dep-table-grid gap-3 sm:gap-2 items-end dep-row" style="background-color: #EEEEF2; border: 1px solid #DCDCE0;">
                  <div>
                    <label class="intake-label sm:sr-only" for={`dep${n}-name`}>Dependent {n} Name</label>
                    <input class="intake-input" type="text" id={`dep${n}-name`} name={`dep${n}_full_name`} placeholder="Full legal name" />
                  </div>
                  <div>
                    <label class="intake-label sm:sr-only" for={`dep${n}-dob`}>Date of Birth</label>
                    <input class="intake-input" type="date" id={`dep${n}-dob`} name={`dep${n}_dob`} />
                  </div>
                  <div>
                    <label class="intake-label sm:sr-only" for={`dep${n}-ssn`}>SSN Last 4</label>
                    <input class="intake-input" type="text" id={`dep${n}-ssn`} name={`dep${n}_ssn_last4`} placeholder="XXXX" maxlength="4" inputmode="numeric" />
                  </div>
                  <div>
                    <label class="intake-label sm:sr-only" for={`dep${n}-rel`}>Relationship</label>
                    <select class="intake-input" id={`dep${n}-rel`} name={`dep${n}_relationship`}>
                      <option value="">Relationship...</option>
                      <option>Child</option>
                      <option>Stepchild</option>
                      <option>Parent</option>
                      <option>Sibling</option>
                      <option>Other Relative</option>
                      <option>Non-Relative</option>
                    </select>
                  </div>
                </div>
              ))}
            </div>
            <p class="text-xs mt-3" style="color: #6B7280;">More than 4 dependents? Add details in the Additional Notes section.</p>
          </fieldset>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 2 · BUSINESS OVERVIEW
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Business Overview</h2>
          <p class="intake-card-sub">Schedule C — Profit or Loss from Business (Sole Proprietorship)</p>
        </div>
        <div class="intake-card-body space-y-6">

          <!-- Business Identity -->
          <fieldset>
            <legend class="intake-legend">Business Identity</legend>
            <div class="intake-grid">
              <div class="sm:col-span-2">
                <label class="intake-label" for="biz-name">Legal Business Name</label>
                <input class="intake-input" type="text" id="biz-name" name="business_name" placeholder="e.g. Smith Consulting, or your own name if sole proprietor" />
              </div>
              <div>
                <label class="intake-label" for="biz-ein">EIN <span class="font-normal">(last 4 digits only)</span></label>
                <input class="intake-input" type="text" id="biz-ein" name="business_ein_last4" placeholder="XXXX" maxlength="4" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label" for="biz-industry">Industry / Business Type</label>
                <input class="intake-input" type="text" id="biz-industry" name="business_industry" placeholder="e.g. Medical practice, IT consulting, real estate" />
              </div>
              <div>
                <label class="intake-label" for="tax-year">Tax Year</label>
                <select class="intake-input" id="tax-year" name="tax_year">
                  <option value="">Select...</option>
                  <option value="2024">2024</option>
                  <option value="2023">2023</option>
                  <option value="2022">2022</option>
                  <option value="prior">Prior Year</option>
                </select>
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Business Address -->
          <fieldset>
            <legend class="intake-legend">Business Address <span class="legend-optional">(if different from home address)</span></legend>
            <div class="intake-grid">
              <div class="sm:col-span-2">
                <label class="intake-label" for="biz-street">Street Address</label>
                <input class="intake-input" type="text" id="biz-street" name="business_address_street" placeholder="Or leave blank if same as home address" />
              </div>
              <div>
                <label class="intake-label" for="biz-city">City</label>
                <input class="intake-input" type="text" id="biz-city" name="business_address_city" />
              </div>
              <div>
                <label class="intake-label" for="biz-state">State</label>
                <select class="intake-input" id="biz-state" name="business_address_state">
                  <option value="">Select...</option>
                  <option value="same">Same as home address</option>
                  <option value="NJ">New Jersey</option>
                  <option value="NY">New York</option>
                  <option value="CT">Connecticut</option>
                  <option value="PA">Pennsylvania</option>
                  <option value="OTHER">Other</option>
                </select>
              </div>
              <div>
                <label class="intake-label" for="biz-zip">ZIP Code</label>
                <input class="intake-input" type="text" id="biz-zip" name="business_address_zip" placeholder="07604" maxlength="10" inputmode="numeric" />
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Accounting Method & Material Participation (side by side) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <fieldset>
              <legend class="intake-legend">Accounting Method</legend>
              <p class="text-xs mb-3" style="color: #6B7280;">How does your business recognize income and expenses?</p>
              <div class="space-y-2">
                {[
                  { value: "cash", label: "Cash Basis", sub: "Income when received, expenses when paid" },
                  { value: "accrual", label: "Accrual Basis", sub: "Income when earned, expenses when incurred" },
                  { value: "unsure", label: "Not Sure / Ask CPA", sub: "" },
                ].map(opt => (
                  <label class="intake-radio-card w-full flex-col items-start gap-0.5">
                    <div class="flex items-center gap-2">
                      <input type="radio" name="accounting_method" value={opt.value} class="sr-only" />
                      <span class="intake-radio-dot flex-shrink-0"></span>
                      <span class="text-sm font-semibold" style="color: #1C1C1E;">{opt.label}</span>
                    </div>
                    {opt.sub && <p class="text-xs pl-6" style="color: #6B7280;">{opt.sub}</p>}
                  </label>
                ))}
              </div>
            </fieldset>

            <fieldset>
              <legend class="intake-legend">Material Participation</legend>
              <p class="text-xs mb-3" style="color: #6B7280;">Do you actively work in this business on a regular, continuous, and substantial basis?</p>
              <div class="space-y-2">
                {[
                  { value: "yes", label: "Yes — I actively run this business" },
                  { value: "no", label: "No — Passive / Investment role" },
                  { value: "unsure", label: "Not Sure / Ask CPA" },
                ].map(opt => (
                  <label class="intake-radio-card w-full">
                    <input type="radio" name="material_participation" value={opt.value} class="sr-only" />
                    <span class="intake-radio-dot flex-shrink-0"></span>
                    <span class="text-sm font-medium" style="color: #1C1C1E;">{opt.label}</span>
                  </label>
                ))}
              </div>
            </fieldset>
          </div>

          <hr class="intake-divider" />

          <!-- Gross Revenue -->
          <fieldset>
            <legend class="intake-legend">Gross Revenue & Returns</legend>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="gross-receipts">Gross Receipts / Sales</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="gross-receipts" name="gross_receipts" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
              <div>
                <label class="intake-label" for="returns-allowances">Returns & Allowances</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="returns-allowances" name="returns_allowances" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
              <div>
                <label class="intake-label" for="cost-goods-sold">Cost of Goods Sold (COGS)</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="cost-goods-sold" name="cost_of_goods_sold" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
              <div>
                <label class="intake-label" for="other-income">Other Business Income</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="other-income" name="other_business_income" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
            </div>
          </fieldset>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 3 · OPERATING EXPENSES
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Operating Expenses</h2>
          <p class="intake-card-sub">Enter approximate annual amounts — exact totals are confirmed from your records. Leave blank if not applicable.</p>
        </div>
        <div class="intake-card-body">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
            {expenseCategories.map(cat => (
              <div>
                <label class="intake-label" for={cat.name}>{cat.label}</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id={cat.name} name={cat.name} placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
            ))}
          </div>
          <div class="mt-6">
            <label class="intake-label" for="expense-notes">Expense Notes <span class="font-normal">(optional)</span></label>
            <textarea class="intake-input" id="expense-notes" name="expense_notes" rows="3" placeholder="Describe any significant or unusual expenses, subcontractor arrangements, inventory details, etc."></textarea>
          </div>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 4 · HOME OFFICE & VEHICLE
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Home Office & Vehicle Use</h2>
          <p class="intake-card-sub">Form 8829 (Home Office) and Schedule C Part IV / Form 4562 (Vehicle)</p>
        </div>
        <div class="intake-card-body space-y-6">

          <!-- Home Office -->
          <fieldset>
            <legend class="intake-legend">Home Office</legend>
            <div class="mb-4">
              <p class="text-sm font-semibold mb-2" style="color: #1C1C1E;">Do you use part of your home exclusively and regularly for business?</p>
              <div class="flex gap-3 flex-wrap">
                {[
                  { value: "yes", label: "Yes" },
                  { value: "no", label: "No" },
                  { value: "unsure", label: "Not Sure" },
                ].map(opt => (
                  <label class="intake-toggle-option">
                    <input type="radio" name="home_office_use" value={opt.value} class="sr-only" />
                    <span class="intake-toggle-btn">{opt.label}</span>
                  </label>
                ))}
              </div>
            </div>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="office-sqft">Office Square Footage (sq ft)</label>
                <input class="intake-input" type="number" id="office-sqft" name="home_office_sqft" placeholder="e.g. 150" min="0" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label" for="home-sqft">Total Home Square Footage (sq ft)</label>
                <input class="intake-input" type="number" id="home-sqft" name="home_total_sqft" placeholder="e.g. 2200" min="0" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label" for="home-mortgage-interest">Annual Mortgage Interest or Rent</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="home-mortgage-interest" name="home_mortgage_interest_or_rent" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
              <div>
                <label class="intake-label" for="home-property-tax">Annual Property Tax</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="home-property-tax" name="home_property_tax" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
              <div>
                <label class="intake-label" for="home-utilities">Annual Utilities</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="home-utilities" name="home_utilities" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
              <div>
                <label class="intake-label" for="home-insurance">Annual Homeowners / Renters Insurance</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="home-insurance" name="home_insurance" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Vehicle -->
          <fieldset>
            <legend class="intake-legend">Vehicle Use</legend>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="vehicle-make-model">Vehicle Make & Model</label>
                <input class="intake-input" type="text" id="vehicle-make-model" name="vehicle_make_model" placeholder="e.g. 2022 Toyota Camry" />
              </div>
              <div>
                <label class="intake-label" for="vehicle-year">Vehicle Year</label>
                <input class="intake-input" type="text" id="vehicle-year" name="vehicle_year" placeholder="e.g. 2022" maxlength="4" inputmode="numeric" />
              </div>
              <div>
