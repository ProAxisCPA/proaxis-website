  .intake-input { display: block; width: 100%; padding: 0.75rem 1rem; border-radius: 0.625rem; border: 1.5px solid #DCDCE0; background-color: #ffffff; color: #1C1C1E; font-size: 0.9375rem; line-height: 1.5; transition: border-color 0.15s, box-shadow 0.15s; -webkit-appearance: none; appearance: none; }
  .intake-input:focus { outline: none; border-color: #2E75B6; box-shadow: 0 0 0 3px rgba(46, 117, 182, 0.15); }
