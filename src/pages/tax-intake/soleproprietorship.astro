  .intake-radio-card:has(input:checked) .intake-radio-dot::after { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 0.5rem; height: 0.5rem; border-radius: 50%; background-color: #2E75B6; }

  /* Toggle buttons */
