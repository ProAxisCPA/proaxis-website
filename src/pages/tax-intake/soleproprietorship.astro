  /* Radio cards */
  .intake-radio-card { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1rem; border-radius: 0.625rem; border: 1.5px solid #DCDCE0; background-color: white; cursor: pointer; transition: border-color 0.15s, background-color 0.15s; user-select: none; }
  .intake-radio-card:has(input:checked) { border-color: #2E75B6; background-color: #EEF3FA; }
  .intake-radio-dot { width: 1rem; height: 1rem; border-radius: 50%; border: 1.5px solid #BDBDC4; flex-shrink: 0; position: relative; background: white; transition: border-color 0.1s; }
