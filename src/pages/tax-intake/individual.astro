---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Individual Tax Strategy Intake | ProAxis CPA";
const description = "Complete your individual tax strategy intake form for ProAxis Tax & Accounting Services. Securely share the details we need to identify deductions and make your consultation as productive as possible.";
const canonical = "/tax-intake/individual/";
---

<BaseLayout {title} {description} {canonical} noindex={true}>

  <!-- Page Header -->
  <section style="background: linear-gradient(135deg, #1C1C1E 0%, #2a2a2e 100%);" class="py-14 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: #C5A55A;">ProAxis Tax & Accounting Services</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-heading text-white mb-5">
        Individual Tax Strategy Intake
      </h1>
      <p class="text-base sm:text-lg leading-relaxed max-w-2xl mx-auto" style="color: #A0A0A8;">
        This information allows us to identify potential deductions and make our consultation as productive as possible.
        Please provide the <strong class="text-white">last 4 digits</strong> of sensitive IDs only.
      </p>
    </div>
  </section>

  <!-- Form -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <form
      data-netlify="true"
      name="individual-tax-intake"
      method="POST"
      action="/tax-intake/success/"
      netlify-honeypot="bot-field"
      class="space-y-8"
      id="ind-intake-form"
    >
      <input type="hidden" name="form-name" value="individual-tax-intake" />
      <input type="hidden" name="subject" id="form-subject" value="New Individual Intake Submission" />
      <p class="hidden" aria-hidden="true"><label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>

      <!-- ─────────────────────────────────────────────
           SECTION 1 · PERSONAL IDENTITY
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Personal Identity</h2>
          <p class="intake-card-sub">Taxpayer & Spouse Information</p>
        </div>
        <div class="intake-card-body space-y-6">

          <!-- Taxpayer -->
          <fieldset>
            <legend class="intake-legend">Taxpayer (Primary)</legend>
            <div class="intake-grid">
              <div class="sm:col-span-2">
                <label class="intake-label" for="tp-name">Full Legal Name</label>
                <input class="intake-input" type="text" id="tp-name" name="taxpayer_full_name" placeholder="As it appears on your Social Security card or ID" autocomplete="name" />
              </div>
              <div>
                <label class="intake-label" for="tp-dob">Date of Birth</label>
                <input class="intake-input" type="date" id="tp-dob" name="taxpayer_dob" />
              </div>
              <div>
                <label class="intake-label" for="tp-ssn">Last 4 of SSN / ITIN</label>
                <input class="intake-input" type="text" id="tp-ssn" name="taxpayer_ssn_last4" placeholder="XXXX" maxlength="4" pattern="\d{4}" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label" for="tp-occupation">Occupation / Job Title</label>
                <input class="intake-input" type="text" id="tp-occupation" name="taxpayer_occupation" placeholder="e.g. Physician, Consultant" />
              </div>
              <div>
                <label class="intake-label" for="tp-employer">Employer / Business Name</label>
                <input class="intake-input" type="text" id="tp-employer" name="taxpayer_employer" placeholder="Current employer or Self-employed" />
              </div>
              <div>
                <label class="intake-label" for="tp-email">Email Address</label>
                <input class="intake-input" type="email" id="tp-email" name="taxpayer_email" placeholder="you@example.com" autocomplete="email" />
              </div>
              <div>
                <label class="intake-label" for="tp-phone">Phone Number</label>
                <input class="intake-input" type="tel" id="tp-phone" name="taxpayer_phone" placeholder="(201) 000-0000" autocomplete="tel" />
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Spouse -->
          <fieldset>
            <legend class="intake-legend">Spouse / Partner <span class="legend-optional">(if applicable)</span></legend>
            <div class="intake-grid">
              <div class="sm:col-span-2">
                <label class="intake-label" for="sp-name">Full Legal Name</label>
                <input class="intake-input" type="text" id="sp-name" name="spouse_full_name" placeholder="As it appears on their Social Security card or ID" />
              </div>
              <div>
                <label class="intake-label" for="sp-dob">Date of Birth</label>
                <input class="intake-input" type="date" id="sp-dob" name="spouse_dob" />
              </div>
              <div>
                <label class="intake-label" for="sp-ssn">Last 4 of SSN / ITIN</label>
                <input class="intake-input" type="text" id="sp-ssn" name="spouse_ssn_last4" placeholder="XXXX" maxlength="4" pattern="\d{4}" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label" for="sp-occupation">Occupation / Job Title</label>
                <input class="intake-input" type="text" id="sp-occupation" name="spouse_occupation" placeholder="e.g. Attorney, RN" />
              </div>
              <div>
                <label class="intake-label" for="sp-employer">Employer / Business Name</label>
                <input class="intake-input" type="text" id="sp-employer" name="spouse_employer" />
              </div>
            </div>
          </fieldset>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 2 · RESIDENCY
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Residency</h2>
          <p class="intake-card-sub">Primary home address as of December 31 of the tax year</p>
        </div>
        <div class="intake-card-body">
          <div class="intake-grid">
            <div class="sm:col-span-2">
              <label class="intake-label" for="addr-street">Street Address</label>
              <input class="intake-input" type="text" id="addr-street" name="address_street" placeholder="123 Main Street, Apt 4B" autocomplete="street-address" />
            </div>
            <div>
              <label class="intake-label" for="addr-city">City</label>
              <input class="intake-input" type="text" id="addr-city" name="address_city" placeholder="Hasbrouck Heights" autocomplete="address-level2" />
            </div>
            <div>
              <label class="intake-label" for="addr-state">State</label>
              <select class="intake-input" id="addr-state" name="address_state" autocomplete="address-level1">
                <option value="">Select state</option>
                <option value="NJ" selected>New Jersey</option>
                <option value="NY">New York</option>
                <option value="CT">Connecticut</option>
                <option value="PA">Pennsylvania</option>
                <option value="DE">Delaware</option>
                <option value="CA">California</option>
                <option value="FL">Florida</option>
                <option value="TX">Texas</option>
                <option value="OTHER">Other</option>
              </select>
            </div>
            <div>
              <label class="intake-label" for="addr-zip">ZIP Code</label>
              <input class="intake-input" type="text" id="addr-zip" name="address_zip" placeholder="07604" maxlength="10" inputmode="numeric" autocomplete="postal-code" />
            </div>
            <div>
              <label class="intake-label" for="addr-county">County</label>
              <input class="intake-input" type="text" id="addr-county" name="address_county" placeholder="Bergen" />
            </div>
          </div>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 3 · FILING STATUS & TAX YEAR
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Filing Status & Tax Year</h2>
          <p class="intake-card-sub">Select the status and year that apply to this return</p>
        </div>
        <div class="intake-card-body space-y-6">
          <div>
            <label class="intake-label" for="tax-year">Tax Year</label>
            <select class="intake-input" id="tax-year" name="tax_year" style="max-width: 200px;">
              <option value="">Select...</option>
              <option value="2024">2024</option>
              <option value="2023">2023</option>
              <option value="2022">2022</option>
              <option value="prior">Prior Year</option>
            </select>
          </div>
          <hr class="intake-divider" />
          <fieldset>
            <legend class="sr-only">Filing Status</legend>
            <div class="intake-grid">
              {[
                { value: "single", label: "Single" },
                { value: "mfj", label: "Married Filing Jointly (MFJ)" },
                { value: "mfs", label: "Married Filing Separately (MFS)" },
                { value: "hoh", label: "Head of Household (HOH)" },
                { value: "qss", label: "Qualifying Surviving Spouse" },
              ].map(opt => (
                <label class="intake-radio-card">
                  <input type="radio" name="filing_status" value={opt.value} class="sr-only" />
                  <span class="intake-radio-dot"></span>
                  <span class="text-sm font-medium" style="color: #1C1C1E;">{opt.label}</span>
                </label>
              ))}
            </div>
          </fieldset>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 4 · DEPENDENTS
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Dependents</h2>
          <p class="intake-card-sub">List all dependents you are claiming on this return</p>
        </div>
        <div class="intake-card-body">
          <!-- Compact table header -->
          <div class="hidden sm:grid dep-table-grid gap-2 mb-2 px-1">
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Full Legal Name</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Date of Birth</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">SSN Last 4</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Relationship</p>
          </div>
          <div class="space-y-2">
            {[1, 2, 3, 4].map(n => (
              <div class="rounded-xl p-3 sm:p-0 sm:rounded-none grid grid-cols-1 sm:dep-table-grid gap-3 sm:gap-2 items-end dep-row" style="background-color: #EEEEF2; border: 1px solid #DCDCE0;">
                <div>
                  <label class="intake-label sm:sr-only" for={`dep${n}-name`}>Dependent {n} Full Legal Name</label>
                  <input class="intake-input" type="text" id={`dep${n}-name`} name={`dep${n}_full_name`} placeholder="Full legal name" />
                </div>
                <div>
                  <label class="intake-label sm:sr-only" for={`dep${n}-dob`}>Date of Birth</label>
                  <input class="intake-input" type="date" id={`dep${n}-dob`} name={`dep${n}_dob`} />
                </div>
                <div>
                  <label class="intake-label sm:sr-only" for={`dep${n}-ssn`}>SSN Last 4</label>
                  <input class="intake-input" type="text" id={`dep${n}-ssn`} name={`dep${n}_ssn_last4`} placeholder="XXXX" maxlength="4" inputmode="numeric" />
                </div>
                <div>
                  <label class="intake-label sm:sr-only" for={`dep${n}-rel`}>Relationship</label>
                  <select class="intake-input" id={`dep${n}-rel`} name={`dep${n}_relationship`}>
                    <option value="">Relationship...</option>
                    <option>Child</option>
                    <option>Stepchild</option>
                    <option>Parent</option>
                    <option>Sibling</option>
                    <option>Other Relative</option>
                    <option>Non-Relative</option>
                  </select>
                </div>
              </div>
            ))}
          </div>
          <p class="text-xs mt-3" style="color: #6B7280;">More than 4 dependents? Add a note at the bottom.</p>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 5 · INCOME SOURCES
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Income Sources</h2>
          <p class="intake-card-sub">Check all income types you received during the tax year</p>
        </div>
        <div class="intake-card-body">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-1 gap-x-6">
            {[
              { name: "income_w2", label: "W-2 — Wages & Salary" },
              { name: "income_1099nec", label: "1099-NEC — Freelance / Self-Employment" },
              { name: "income_1099k", label: "1099-K — Payment Platforms" },
              { name: "income_1099int", label: "1099-INT — Bank Interest" },
              { name: "income_1099div", label: "1099-DIV — Dividends" },
              { name: "income_1099b", label: "1099-B — Brokerage / Capital Gains" },
              { name: "income_1099r", label: "1099-R — Retirement Distributions" },
              { name: "income_ssa1099", label: "SSA-1099 — Social Security Benefits" },
              { name: "income_k1", label: "K-1 — Partnership, S-Corp, or Trust" },
              { name: "income_schedule_e", label: "Schedule E — Rental Income" },
              { name: "income_alimony", label: "Alimony Received (pre-2019 divorce)" },
              { name: "income_gambling", label: "W-2G — Gambling Winnings" },
              { name: "income_foreign", label: "Foreign Source Income" },
              { name: "income_other", label: "Other Income (describe in notes)" },
            ].map(item => (
              <label class="intake-checkbox-row">
                <input type="checkbox" name={item.name} value="yes" class="intake-checkbox" />
                <span class="text-sm" style="color: #1C1C1E;">{item.label}</span>
              </label>
            ))}
          </div>
          <div class="mt-4">
            <label class="intake-label" for="income-notes">Income notes <span class="font-normal">(optional)</span></label>
            <textarea class="intake-input" id="income-notes" name="income_notes" rows="2" placeholder="e.g. Sold rental property in July, received K-1 from family LLC..."></textarea>
          </div>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 6 · COMPLIANCE & DISCLOSURE
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Compliance & Disclosure</h2>
          <p class="intake-card-sub">Required IRS disclosures — answer Yes or No for each item</p>
        </div>
        <div class="intake-card-body space-y-4">
          {[
            {
              name: "compliance_digital_assets",
              label: "Digital Assets / Cryptocurrency",
              description: "Did you receive, sell, exchange, or otherwise dispose of any digital asset (crypto, NFT, staking rewards) during the year?",
            },
            {
              name: "compliance_foreign_accounts",
              label: "Foreign Bank & Financial Accounts (FBAR / FinCEN 114)",
              description: "Did you have a financial interest in, or signature authority over, any foreign bank, securities, or other financial accounts with an aggregate value exceeding $10,000 at any point?",
            },
            {
              name: "compliance_foreign_trusts",
              label: "Foreign Trusts & Entities",
              description: "Were you the grantor of, or transferor to, a foreign trust? Did you receive a distribution from, or were treated as an owner of, a foreign trust?",
            },
          ].map(item => (
            <div class="rounded-xl p-4" style="background-color: #EEEEF2; border: 1px solid #DCDCE0;">
              <p class="text-sm font-semibold mb-0.5" style="color: #1C1C1E;">{item.label}</p>
              <p class="text-xs mb-3 leading-relaxed" style="color: #6B7280;">{item.description}</p>
              <fieldset>
                <legend class="sr-only">{item.label}</legend>
                <div class="flex gap-3 flex-wrap">
                  {["Yes", "No", "Not Sure"].map(opt => (
                    <label class="intake-toggle-option">
                      <input type="radio" name={item.name} value={opt.toLowerCase().replace(' ', '_')} class="sr-only" />
                      <span class="intake-toggle-btn">{opt}</span>
                    </label>
                  ))}
                </div>
              </fieldset>
            </div>
          ))}
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 7 · DEDUCTIONS & CREDITS
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Deductions & Credits</h2>
          <p class="intake-card-sub">Check all that may apply — eligibility and amounts are confirmed during your consultation</p>
        </div>
        <div class="intake-card-body space-y-6">

          <!-- Itemized Deductions -->
          <div>
            <p class="text-sm font-semibold mb-3 uppercase tracking-wide" style="color: #1C1C1E;">Potential Itemized Deductions (Schedule A)</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-1 gap-x-6">
              {[
                { name: "ded_mortgage_interest", label: "Mortgage Interest (Form 1098)" },
                { name: "ded_property_tax", label: "Real Estate / Property Taxes" },
                { name: "ded_state_income_tax", label: "State & Local Income Tax (SALT)" },
                { name: "ded_medical", label: "Unreimbursed Medical & Dental Expenses" },
                { name: "ded_charity_cash", label: "Charitable Contributions — Cash / Check" },
                { name: "ded_charity_noncash", label: "Charitable Contributions — Non-Cash" },
                { name: "ded_charity_appreciated", label: "Charitable Contributions — Appreciated Securities" },
                { name: "ded_investment_interest", label: "Investment Interest Expense" },
                { name: "ded_casualty_loss", label: "Casualty / Disaster Loss (federally declared)" },
              ].map(item => (
                <label class="intake-checkbox-row">
                  <input type="checkbox" name={item.name} value="yes" class="intake-checkbox" />
                  <span class="text-sm" style="color: #1C1C1E;">{item.label}</span>
                </label>
              ))}
            </div>
          </div>

          <hr class="intake-divider" />

          <!-- Above-the-Line Adjustments -->
          <div>
            <p class="text-sm font-semibold mb-3 uppercase tracking-wide" style="color: #1C1C1E;">Above-the-Line Adjustments</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-1 gap-x-6">
              {[
                { name: "adj_hsa", label: "HSA Contributions (Form 8889)" },
                { name: "adj_student_loan", label: "Student Loan Interest (Form 1098-E)" },
                { name: "adj_ira", label: "Traditional IRA Contributions" },
                { name: "adj_sep_simple", label: "SEP-IRA / SIMPLE IRA Contributions" },
                { name: "adj_self_employed_health", label: "Self-Employed Health Insurance Premiums" },
                { name: "adj_alimony_paid", label: "Alimony Paid (pre-2019 divorce instrument)" },
                { name: "adj_educator_expenses", label: "Educator Expenses (up to $300)" },
                { name: "adj_moving_military", label: "Moving Expenses (active duty military only)" },
              ].map(item => (
                <label class="intake-checkbox-row">
                  <input type="checkbox" name={item.name} value="yes" class="intake-checkbox" />
                  <span class="text-sm" style="color: #1C1C1E;">{item.label}</span>
                </label>
              ))}
            </div>
          </div>

          <hr class="intake-divider" />

          <!-- Tax Credits -->
          <div>
            <p class="text-sm font-semibold mb-3 uppercase tracking-wide" style="color: #1C1C1E;">Potential Tax Credits</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-1 gap-x-6">
              {[
                { name: "credit_child_tax", label: "Child Tax Credit / Additional Child Tax Credit" },
                { name: "credit_ctc_dep", label: "Child & Dependent Care Credit (Form 2441)" },
                { name: "credit_education_aotc", label: "American Opportunity Credit (AOTC)" },
                { name: "credit_education_llc", label: "Lifetime Learning Credit" },
                { name: "credit_ev", label: "Clean Vehicle / EV Purchase Credit (Form 8936)" },
                { name: "credit_energy_home", label: "Energy Efficient Home Improvement Credit" },
                { name: "credit_retirement_saver", label: "Retirement Savings Contributions (Saver's Credit)" },
                { name: "credit_foreign_tax", label: "Foreign Tax Credit (Form 1116)" },
                { name: "credit_eitc", label: "Earned Income Tax Credit (EITC)" },
              ].map(item => (
                <label class="intake-checkbox-row">
                  <input type="checkbox" name={item.name} value="yes" class="intake-checkbox" />
                  <span class="text-sm" style="color: #1C1C1E;">{item.label}</span>
                </label>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 8 · LIFE EVENTS
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Life Events</h2>
          <p class="intake-card-sub">Check any significant events that occurred during the tax year — each can affect your return</p>
        </div>
        <div class="intake-card-body">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-1 gap-x-6">
            {[
              { name: "event_married", label: "Got Married" },
              { name: "event_divorced", label: "Divorced or Separated" },
              { name: "event_newborn", label: "New Child (birth or adoption)" },
              { name: "event_dependent_change", label: "Dependent Added or Removed" },
              { name: "event_moved_state", label: "Moved to a Different State" },
              { name: "event_moved_abroad", label: "Moved Abroad / Expatriated" },
              { name: "event_bought_home", label: "Purchased a Home" },
              { name: "event_sold_home", label: "Sold a Home" },
              { name: "event_sold_rental", label: "Sold Rental or Investment Property" },
              { name: "event_started_business", label: "Started or Acquired a Business" },
              { name: "event_closed_business", label: "Closed or Sold a Business" },
              { name: "event_job_change", label: "Changed Jobs or Was Laid Off" },
              { name: "event_retired", label: "Retired" },
              { name: "event_inheritance", label: "Received an Inheritance or Gift" },
              { name: "event_death_spouse", label: "Death of Spouse or Dependent" },
              { name: "event_irs_notice", label: "Received an IRS or State Tax Notice" },
            ].map(item => (
              <label class="intake-checkbox-row">
                <input type="checkbox" name={item.name} value="yes" class="intake-checkbox" />
                <span class="text-sm" style="color: #1C1C1E;">{item.label}</span>
              </label>
            ))}
          </div>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 9 · PRIOR YEAR & ADDITIONAL NOTES
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Prior Year & Additional Notes</h2>
          <p class="intake-card-sub">Optional but helpful context for your CPA</p>
        </div>
        <div class="intake-card-body space-y-4">
          <div>
            <label class="intake-label" for="prior-cpa">Who prepared your prior year return?</label>
            <input class="intake-input" type="text" id="prior-cpa" name="prior_year_preparer" placeholder="Firm name, software (TurboTax, H&R Block), or Self-prepared" />
          </div>
          <div>
            <label class="intake-label" for="prior-balance">Prior year result (approximate)</label>
            <select class="intake-input" id="prior-balance" name="prior_year_result">
              <option value="">Select...</option>
              <option value="refund_large">Large refund (over $3,000)</option>
              <option value="refund_small">Small refund (under $3,000)</option>
              <option value="breakeven">Roughly break-even</option>
              <option value="owed_small">Owed a small amount (under $2,000)</option>
              <option value="owed_large">Owed a significant amount (over $2,000)</option>
              <option value="unknown">Don't remember</option>
            </select>
          </div>
