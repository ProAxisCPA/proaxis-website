---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "C-Corporation Tax Intake (Form 1120) | ProAxis CPA";
const description = "Complete your C-Corporation tax intake for ProAxis Tax & Accounting Services. Provide the details we need to prepare Form 1120, identify credits, and plan your corporate tax strategy.";
const canonical = "/tax-intake/corporate/";
---

<BaseLayout {title} {description} {canonical} noindex={true}>

  <!-- Page Header -->
  <section style="background: linear-gradient(135deg, #1C1C1E 0%, #2a2a2e 100%);" class="py-14 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: #C5A55A;">ProAxis Tax & Accounting Services</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-heading text-white mb-5">
        C-Corporation Tax Intake
      </h1>
      <p class="text-sm font-semibold uppercase tracking-wide mb-4" style="color: #C5A55A;">Form 1120 — U.S. Corporation Income Tax Return</p>
      <p class="text-base sm:text-lg leading-relaxed max-w-2xl mx-auto" style="color: #A0A0A8;">
        Complete this intake so our CPA team can prepare your federal and state corporate returns, identify every available credit, and build a proactive tax strategy for your corporation.
        Provide the <strong class="text-white">last 4 digits</strong> of EINs and SSNs only.
        Dollar figures are estimates — exact amounts are confirmed from your financials.
      </p>
    </div>
  </section>

  <!-- Form -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <form
      data-netlify="true"
      name="corporate-intake"
      method="POST"
      action="/tax-intake/success/"
      netlify-honeypot="bot-field"
      class="space-y-8"
      id="corp-intake-form"
    >
      <input type="hidden" name="form-name" value="corporate-intake" />
      <input type="hidden" name="subject" id="form-subject" value="New Corporate Intake Submission" />

      <!-- Honeypot -->
      <p class="hidden" aria-hidden="true">
        <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
      </p>

      <!-- ─────────────────────────────────────────────
           SECTION 1 · CORPORATE IDENTITY
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Corporate Identity</h2>
          <p class="intake-card-sub">Legal entity details, tax year, and primary contact</p>
        </div>
        <div class="intake-card-body space-y-6">

          <fieldset>
            <legend class="intake-legend">Entity Information</legend>
            <div class="intake-grid">
              <div class="sm:col-span-2">
                <label class="intake-label" for="corp-name">Legal Corporate Name</label>
                <input class="intake-input" type="text" id="corp-name" name="corporation_name" placeholder="As it appears on the Certificate of Incorporation" />
              </div>
              <div>
                <label class="intake-label" for="corp-dba">DBA / Trade Name <span class="font-normal">(if different)</span></label>
                <input class="intake-input" type="text" id="corp-dba" name="corporation_dba" />
              </div>
              <div>
                <label class="intake-label" for="corp-ein">EIN (Last 4 digits only)</label>
                <input class="intake-input" type="text" id="corp-ein" name="corporation_ein_last4" placeholder="XXXX" maxlength="4" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label" for="corp-state-inc">State of Incorporation</label>
                <select class="intake-input" id="corp-state-inc" name="state_of_incorporation">
                  <option value="">Select...</option>
                  <option value="DE">Delaware</option>
                  <option value="NJ">New Jersey</option>
                  <option value="NY">New York</option>
                  <option value="NV">Nevada</option>
                  <option value="WY">Wyoming</option>
                  <option value="FL">Florida</option>
                  <option value="TX">Texas</option>
                  <option value="CA">California</option>
                  <option value="OTHER">Other</option>
                </select>
              </div>
              <div>
                <label class="intake-label" for="corp-state-op">Principal State of Operations</label>
                <select class="intake-input" id="corp-state-op" name="state_of_operations">
                  <option value="">Select...</option>
                  <option value="NJ" selected>New Jersey</option>
                  <option value="NY">New York</option>
                  <option value="CT">Connecticut</option>
                  <option value="PA">Pennsylvania</option>
                  <option value="DE">Delaware</option>
                  <option value="FL">Florida</option>
                  <option value="TX">Texas</option>
                  <option value="CA">California</option>
                  <option value="OTHER">Other</option>
                </select>
              </div>
              <div>
                <label class="intake-label" for="corp-date-inc">Date of Incorporation</label>
                <input class="intake-input" type="date" id="corp-date-inc" name="date_of_incorporation" />
              </div>
              <div>
                <label class="intake-label" for="corp-industry">Industry / Business Description</label>
                <input class="intake-input" type="text" id="corp-industry" name="business_industry" placeholder="e.g. Technology, Medical devices, Real estate" />
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <fieldset>
            <legend class="intake-legend">Tax Year & Filing Details</legend>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="tax-year-begin">Tax Year Beginning</label>
                <input class="intake-input" type="date" id="tax-year-begin" name="tax_year_begin" />
              </div>
              <div>
                <label class="intake-label" for="tax-year-end">Tax Year Ending</label>
                <input class="intake-input" type="date" id="tax-year-end" name="tax_year_end" />
              </div>
              <div>
                <label class="intake-label" for="accounting-method">Accounting Method</label>
                <select class="intake-input" id="accounting-method" name="accounting_method">
                  <option value="">Select...</option>
                  <option value="cash">Cash Basis</option>
                  <option value="accrual">Accrual Basis</option>
                  <option value="other">Other (describe in notes)</option>
                </select>
              </div>
              <div>
                <label class="intake-label" for="naics-code">NAICS / Business Code</label>
                <input class="intake-input" type="text" id="naics-code" name="naics_code" placeholder="e.g. 541511" />
              </div>
              <div class="sm:col-span-2">
                <p class="text-sm font-semibold mb-2" style="color: #1C1C1E;">Is this a first-year return?</p>
                <div class="flex gap-3">
                  {["Yes — Initial Return", "No — Ongoing", "Final Return (dissolving)"].map(opt => (
                    <label class="intake-toggle-option">
                      <input type="radio" name="return_type" value={opt} class="sr-only" />
                      <span class="intake-toggle-btn">{opt}</span>
                    </label>
                  ))}
                </div>
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <fieldset>
            <legend class="intake-legend">Registered & Principal Office Address</legend>
            <div class="intake-grid">
              <div class="sm:col-span-2">
                <label class="intake-label" for="corp-street">Street Address</label>
                <input class="intake-input" type="text" id="corp-street" name="corp_address_street" placeholder="123 Business Park Drive, Suite 200" />
              </div>
              <div>
                <label class="intake-label" for="corp-city">City</label>
                <input class="intake-input" type="text" id="corp-city" name="corp_address_city" />
              </div>
              <div>
                <label class="intake-label" for="corp-state">State</label>
                <select class="intake-input" id="corp-state" name="corp_address_state">
                  <option value="">Select...</option>
                  <option value="NJ" selected>New Jersey</option>
                  <option value="NY">New York</option>
                  <option value="CT">Connecticut</option>
                  <option value="PA">Pennsylvania</option>
                  <option value="DE">Delaware</option>
                  <option value="OTHER">Other</option>
                </select>
              </div>
              <div>
                <label class="intake-label" for="corp-zip">ZIP Code</label>
                <input class="intake-input" type="text" id="corp-zip" name="corp_address_zip" placeholder="07604" maxlength="10" inputmode="numeric" />
              </div>
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <fieldset>
            <legend class="intake-legend">Primary Contact for This Return</legend>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="contact-name">Full Legal Name & Title</label>
                <input class="intake-input" type="text" id="contact-name" name="contact_full_name_title" placeholder="As it appears on your Social Security card or ID — e.g. Jane A. Smith, CFO" />
              </div>
              <div>
                <label class="intake-label" for="contact-email">Email Address</label>
                <input class="intake-input" type="email" id="contact-email" name="contact_email" placeholder="cfo@company.com" />
              </div>
              <div>
                <label class="intake-label" for="contact-phone">Phone Number</label>
                <input class="intake-input" type="tel" id="contact-phone" name="contact_phone" placeholder="(201) 000-0000" />
              </div>
              <div>
                <label class="intake-label" for="contact-website">Corporate Website</label>
                <input class="intake-input" type="url" id="contact-website" name="corporate_website" placeholder="https://" />
              </div>
            </div>
          </fieldset>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 2 · OFFICERS & OWNERSHIP
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Officers & Ownership</h2>
          <p class="intake-card-sub">Form 1120 Schedule E — Compensation of Officers; ownership percentage and SSN (last 4)</p>
        </div>
        <div class="intake-card-body space-y-5">

          <!-- Column headers -->
          <div class="hidden sm:grid officer-grid gap-2 px-1">
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Officer Name</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Title</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">SSN (Last 4)</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">% Stock Owned</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Time Devoted %</p>
            <p class="text-xs font-semibold uppercase tracking-wide" style="color: #6B7280;">Compensation ($)</p>
          </div>

          {[1,2,3,4].map(n => (
            <div class="rounded-xl p-4 sm:p-0 sm:rounded-none grid grid-cols-1 sm:officer-grid gap-3 sm:gap-2 items-end officer-row" style="background-color: #EEEEF2; border: 1px solid #DCDCE0;">
              <div>
                <label class="intake-label sm:sr-only" for={`off${n}-name`}>Officer {n} Full Legal Name</label>
                <input class="intake-input" type="text" id={`off${n}-name`} name={`officer${n}_full_name`} placeholder="As it appears on their Social Security card or ID" />
              </div>
              <div>
                <label class="intake-label sm:sr-only" for={`off${n}-title`}>Title</label>
                <input class="intake-input" type="text" id={`off${n}-title`} name={`officer${n}_title`} placeholder="CEO, CFO, President..." />
              </div>
              <div>
                <label class="intake-label sm:sr-only" for={`off${n}-ssn`}>SSN Last 4</label>
                <input class="intake-input" type="text" id={`off${n}-ssn`} name={`officer${n}_ssn_last4`} placeholder="XXXX" maxlength="4" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label sm:sr-only" for={`off${n}-stock`}>Stock Owned %</label>
                <div class="relative">
                  <input class="intake-input pr-8" type="number" id={`off${n}-stock`} name={`officer${n}_stock_pct`} placeholder="0" min="0" max="100" inputmode="numeric" />
                  <span class="pct-suffix">%</span>
                </div>
              </div>
              <div>
                <label class="intake-label sm:sr-only" for={`off${n}-time`}>Time Devoted %</label>
                <div class="relative">
                  <input class="intake-input pr-8" type="number" id={`off${n}-time`} name={`officer${n}_time_devoted_pct`} placeholder="100" min="0" max="100" inputmode="numeric" />
                  <span class="pct-suffix">%</span>
                </div>
              </div>
              <div>
                <label class="intake-label sm:sr-only" for={`off${n}-comp`}>Compensation</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id={`off${n}-comp`} name={`officer${n}_compensation`} placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
            </div>
          ))}

          <p class="text-xs" style="color: #6B7280;">More than 4 officers? Add details in the Additional Notes section.</p>

          <hr class="intake-divider" />

          <!-- Shareholder details -->
          <fieldset>
            <legend class="intake-legend">Shareholder Information</legend>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="total-shares">Total Shares Authorized</label>
                <input class="intake-input" type="number" id="total-shares" name="total_shares_authorized" placeholder="e.g. 10,000,000" inputmode="numeric" />
              </div>
              <div>
                <label class="intake-label" for="shares-outstanding">Shares Outstanding</label>
                <input class="intake-input" type="number" id="shares-outstanding" name="shares_outstanding" placeholder="e.g. 1,000,000" inputmode="numeric" />
              </div>
              <div class="sm:col-span-2">
                <label class="intake-label" for="share-classes">Share Classes Issued</label>
                <input class="intake-input" type="text" id="share-classes" name="share_classes" placeholder="e.g. Common only; or Common + Series A Preferred" />
              </div>
            </div>

            <div class="mt-4">
              <p class="text-sm font-semibold mb-2" style="color: #1C1C1E;">Does any shareholder own 20% or more of the corporation's stock?</p>
              <div class="flex gap-3">
                {["Yes", "No"].map(opt => (
                  <label class="intake-toggle-option">
                    <input type="radio" name="twenty_pct_shareholder" value={opt.toLowerCase()} class="sr-only" />
                    <span class="intake-toggle-btn">{opt}</span>
                  </label>
                ))}
              </div>
            </div>
            <div class="mt-4">
              <p class="text-sm font-semibold mb-2" style="color: #1C1C1E;">Is this corporation a member of a controlled group?</p>
              <div class="flex gap-3">
                {["Yes", "No", "Not Sure"].map(opt => (
                  <label class="intake-toggle-option">
                    <input type="radio" name="controlled_group" value={opt.toLowerCase().replace(' ', '_')} class="sr-only" />
                    <span class="intake-toggle-btn">{opt}</span>
                  </label>
                ))}
              </div>
            </div>
            <div class="mt-4">
              <p class="text-sm font-semibold mb-2" style="color: #1C1C1E;">Are there any foreign shareholders (>25% foreign ownership)?</p>
              <div class="flex gap-3">
                {["Yes", "No"].map(opt => (
                  <label class="intake-toggle-option">
                    <input type="radio" name="foreign_shareholders" value={opt.toLowerCase()} class="sr-only" />
                    <span class="intake-toggle-btn">{opt}</span>
                  </label>
                ))}
              </div>
            </div>
          </fieldset>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 3 · INCOME & DEDUCTIONS
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Income & Deductions</h2>
          <p class="intake-card-sub">Form 1120 Page 1 — Revenue sources and standard corporate deductions. Enter approximate annual totals.</p>
        </div>
        <div class="intake-card-body space-y-6">

          <!-- Income -->
          <fieldset>
            <legend class="intake-legend">Gross Income</legend>
            <div class="intake-grid">
              {[
                { name: "gross_receipts_sales", label: "Gross Receipts or Sales" },
                { name: "returns_allowances", label: "Less: Returns & Allowances" },
                { name: "cost_of_goods_sold", label: "Cost of Goods Sold (COGS)" },
                { name: "dividends_received", label: "Dividends Received" },
                { name: "interest_income", label: "Interest Income" },
                { name: "gross_rents", label: "Gross Rents" },
                { name: "gross_royalties", label: "Gross Royalties" },
                { name: "capital_gain_net", label: "Capital Gain Net Income (Schedule D)" },
                { name: "net_gain_1231", label: "Net Gain / Loss from Form 4797" },
                { name: "other_income", label: "Other Income" },
              ].map(item => (
                <div>
                  <label class="intake-label" for={item.name}>{item.label}</label>
                  <div class="relative">
                    <span class="dollar-prefix">$</span>
                    <input class="intake-input intake-dollar" type="text" id={item.name} name={item.name} placeholder="0.00" inputmode="decimal" />
                  </div>
                </div>
              ))}
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Deductions -->
          <fieldset>
            <legend class="intake-legend">Corporate Deductions</legend>
            <div class="intake-grid">
              {[
                { name: "ded_compensation_officers", label: "Compensation of Officers (Schedule E)" },
                { name: "ded_salaries_wages", label: "Salaries & Wages (non-officer)" },
                { name: "ded_repairs_maintenance", label: "Repairs & Maintenance" },
                { name: "ded_bad_debts", label: "Bad Debts" },
                { name: "ded_rents", label: "Rents Paid" },
                { name: "ded_taxes_licenses", label: "Taxes & Licenses" },
                { name: "ded_interest", label: "Interest Expense" },
                { name: "ded_charitable_contributions", label: "Charitable Contributions" },
                { name: "ded_depreciation", label: "Depreciation (Form 4562)" },
                { name: "ded_depletion", label: "Depletion" },
                { name: "ded_advertising", label: "Advertising & Marketing" },
                { name: "ded_pension_profit_sharing", label: "Pension / Profit-Sharing Plans" },
                { name: "ded_employee_benefit_programs", label: "Employee Benefit Programs" },
                { name: "ded_domestic_production", label: "Qualified Business Income / Domestic Production" },
                { name: "ded_other_deductions", label: "Other Deductions (Schedule attached)" },
              ].map(item => (
                <div>
                  <label class="intake-label" for={item.name}>{item.label}</label>
                  <div class="relative">
                    <span class="dollar-prefix">$</span>
                    <input class="intake-input intake-dollar" type="text" id={item.name} name={item.name} placeholder="0.00" inputmode="decimal" />
                  </div>
                </div>
              ))}
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- Tax & Payments -->
          <fieldset>
            <legend class="intake-legend">Taxes Paid & Estimated Payments</legend>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="est-payments-federal">Federal Estimated Tax Payments</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="est-payments-federal" name="estimated_payments_federal" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
              <div>
                <label class="intake-label" for="est-payments-state">State Estimated Tax Payments</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="est-payments-state" name="estimated_payments_state" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
              <div>
                <label class="intake-label" for="prior-year-overpayment">Prior Year Overpayment Applied</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="prior-year-overpayment" name="prior_year_overpayment_applied" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
              <div>
                <label class="intake-label" for="nol-carryforward">Net Operating Loss (NOL) Carryforward</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="nol-carryforward" name="nol_carryforward" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
            </div>
          </fieldset>

          <div class="mt-4">
            <label class="intake-label" for="income-notes">Income & Deduction Notes</label>
            <textarea class="intake-input" id="income-notes" name="income_deduction_notes" rows="3" placeholder="Describe any unusual revenue streams, intercompany transactions, related-party rents, or deductions that require additional context..."></textarea>
          </div>
        </div>
      </div>

      <!-- ─────────────────────────────────────────────
           SECTION 4 · TAX CREDITS
      ───────────────────────────────────────────── -->
      <div class="intake-card">
        <div class="intake-card-header">
          <h2 class="intake-card-title">Tax Credits</h2>
          <p class="intake-card-sub">Corporate tax credits can directly reduce your tax liability dollar-for-dollar — check all that may apply</p>
        </div>
        <div class="intake-card-body space-y-6">

          <!-- Credit Checkboxes -->
          <fieldset>
            <legend class="intake-legend">Applicable Credits — Check All That Apply</legend>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-1 gap-x-6">
              {[
                { name: "credit_rd", label: "R&D Tax Credit (IRC §41) — Research & Experimentation" },
                { name: "credit_erc", label: "Employee Retention Credit (ERC / ERTC)" },
                { name: "credit_wotc", label: "Work Opportunity Tax Credit (WOTC)" },
                { name: "credit_disabled_access", label: "Disabled Access Credit (§44)" },
                { name: "credit_energy_investment", label: "Energy Investment Tax Credit (ITC / §48)" },
                { name: "credit_clean_vehicle_commercial", label: "Commercial Clean Vehicle Credit (§45W)" },
                { name: "credit_alternative_fuel", label: "Alternative Fuel Vehicle Refueling Credit (§30C)" },
                { name: "credit_low_income_housing", label: "Low-Income Housing Tax Credit (LIHTC / §42)" },
                { name: "credit_new_markets", label: "New Markets Tax Credit (NMTC / §45D)" },
                { name: "credit_foreign_tax", label: "Foreign Tax Credit (§901)" },
                { name: "credit_general_business", label: "General Business Credit Carryforward (Form 3800)" },
                { name: "credit_employer_childcare", label: "Employer-Provided Childcare Credit (§45F)" },
                { name: "credit_family_medical_leave", label: "Paid Family & Medical Leave Credit (§45S)" },
                { name: "credit_opportunity_zone", label: "Qualified Opportunity Zone Investment" },
              ].map(item => (
                <label class="intake-checkbox-row">
                  <input type="checkbox" name={item.name} value="yes" class="intake-checkbox" />
                  <span class="text-sm" style="color: #1C1C1E;">{item.label}</span>
                </label>
              ))}
            </div>
          </fieldset>

          <hr class="intake-divider" />

          <!-- R&D Deep Dive -->
          <fieldset>
            <legend class="intake-legend">R&D Credit Detail <span class="legend-optional">(if applicable — IRC §41)</span></legend>
            <p class="text-xs mb-4" style="color: #6B7280;">
              The R&D credit rewards qualified research activities. Documentation requirements are strict — the more detail you provide, the better we can quantify the credit.
            </p>
            <div class="intake-grid">
              <div>
                <label class="intake-label" for="rd-wages">Qualified Research Wages</label>
                <div class="relative">
                  <span class="dollar-prefix">$</span>
                  <input class="intake-input intake-dollar" type="text" id="rd-wages" name="rd_qualified_wages" placeholder="0.00" inputmode="decimal" />
                </div>
              </div>
