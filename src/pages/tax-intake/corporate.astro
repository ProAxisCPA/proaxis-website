<script>
  const form = document.getElementById('corp-intake-form');
  const corpNameInput = form?.querySelector<HTMLInputElement>('[name="corporation_name"]');
  const subjectInput  = form?.querySelector<HTMLInputElement>('[name="subject"]');

  if (corpNameInput && subjectInput) {
    corpNameInput.addEventListener('input', () => {
      const name = corpNameInput.value.trim();
      subjectInput.value = name
        ? `New Corporate Intake Submission: ${name}`
        : 'New Corporate Intake Submission';
    });
  }

  const emailInput = form?.querySelector<HTMLInputElement>('[name="contact_email"]');
  if (emailInput && form) {
    emailInput.addEventListener('change', () => {
      let replyTo = form.querySelector<HTMLInputElement>('[name="reply-to"]');
      if (!replyTo) {
        replyTo = document.createElement('input');
        replyTo.type = 'hidden';
        replyTo.name = 'reply-to';
        form.appendChild(replyTo);
      }
      replyTo.value = emailInput.value;
    });
  }
</script>

