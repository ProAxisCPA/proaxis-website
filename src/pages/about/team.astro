---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/ui/CTASection.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';

const title = "Our CPA Team | ProAxis Tax & Accounting | Bergen County NJ";
const description = "Meet the licensed CPAs and accounting professionals at ProAxis Tax & Accounting Services in Hasbrouck Heights, Bergen County, NJ — a technology-first team dedicated to proactive client service.";
const canonical = "/about/team/";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "AccountingService",
    "name": "ProAxis Tax & Accounting Services",
    "description": "Bergen County CPA firm with a team of licensed CPAs and accounting professionals serving businesses and individuals across New Jersey.",
    "telephone": "+12018002330",
    "url": "https://proaxiscpa.com",
    "areaServed": { "@type": "State", "name": "New Jersey" },
    "founder": {
      "@type": "Person",
      "name": "Dor Israel",
      "jobTitle": "Certified Public Accountant",
      "url": "https://proaxiscpa.com/about/team/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Dor Israel",
    "jobTitle": "Certified Public Accountant",
    "honorificSuffix": "CPA",
    "url": "https://proaxiscpa.com/about/team/",
    "worksFor": {
      "@type": "AccountingService",
      "name": "ProAxis Tax & Accounting Services",
      "url": "https://proaxiscpa.com"
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Hasbrouck Heights",
      "addressRegion": "NJ",
      "postalCode": "07604",
      "addressCountry": "US"
    },
    "knowsAbout": ["Tax Planning", "Tax Preparation", "NJ SALT", "S-Corp Elections", "IRS Tax Resolution", "Bookkeeping", "Business Advisory"],
    "sameAs": ["https://share.google/KNWsK1XsD4OWKdgPi"]
  }
];

const breadcrumbs = [
  { name: "About", url: "/about/" },
  { name: "Our Team" }
];

const teamMembers = [
  {
    name: "Team Member Name",
    title: "Licensed CPA | Managing Member",
    credentials: "CPA, NJ Licensed",
    bio: "With extensive experience in tax planning and business advisory services for New Jersey businesses, our managing CPA brings deep expertise in NJ and federal tax law to every client engagement. Specializations include S-Corp tax planning, real estate investor accounting, and business entity structuring for Bergen County businesses.",
    specializations: ["Tax Planning & Strategy", "Business Entity Structuring", "Real Estate Tax", "NJ BAIT & SALT"],
  },
  {
    name: "Team Member Name",
    title: "Licensed CPA | Tax & Accounting Manager",
    credentials: "CPA, NJ Licensed",
    bio: "Focused on small business accounting and individual tax preparation, our tax and accounting manager brings a meticulous approach to compliance and a talent for identifying deductions that clients often miss. Deep expertise in bookkeeping system setup, payroll compliance, and multi-state tax filing for NJ-based businesses.",
    specializations: ["Small Business Accounting", "Individual Tax Returns", "Payroll Compliance", "Bookkeeping Systems"],
  },
  {
    name: "Team Member Name",
    title: "Senior Accountant | Advisory Services",
    credentials: "CPA Candidate",
    bio: "Our senior accountant specializes in financial statement preparation, business performance analysis, and supporting clients in understanding the financial health of their businesses. Works closely with our fractional CFO clients to deliver the reporting and analysis they need to make informed strategic decisions.",
    specializations: ["Financial Statements", "Business Performance Analysis", "Fractional CFO Support", "Cash Flow Planning"],
  },
];
---

<BaseLayout {title} {description} {canonical} {schema} {breadcrumbs}>
  <Breadcrumbs items={breadcrumbs} />

  <!-- Hero -->
  <section style="background: linear-gradient(135deg, #1C1C1E 0%, #2E75B6 100%);" class="py-14 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-heading text-white mb-4">
        Meet the ProAxis Team
      </h1>
      <p class="text-lg text-gray-300 mb-8 max-w-2xl">
        Licensed CPAs and accounting professionals dedicated to proactive, expert financial guidance for New Jersey businesses and individuals.
      </p>
      <a href="/contact/" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-lg font-semibold text-white transition-all hover:opacity-90" style="background-color: #22C55E;">
        Schedule Free Consultation
      </a>
    </div>
  </section>

  <!-- Main Content -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">

    <!-- Team Philosophy -->
    <div class="mb-12">
      <h2 class="text-2xl font-bold font-heading mb-5" style="color: #1C1C1E;">Our Team Philosophy</h2>
      <p class="text-gray-700 leading-relaxed mb-4">
        At ProAxis, we believe that the quality of a CPA engagement is determined by the people delivering it. That is why we staff every client relationship with licensed CPAs — not unlicensed preparers or bookkeepers presenting themselves as advisors. Our team members hold active CPA licensure, complete the continuing professional education required to maintain those credentials, and stay current on both federal tax law changes and New Jersey-specific developments throughout the year.
      </p>
      <p class="text-gray-700 leading-relaxed mb-4">
        We are a small, focused team by design. We do not try to serve every type of client in every state. We go deep on the industries and situations where our expertise delivers the most value — and we build long-term relationships with the clients we serve. Most of our clients come to us through referrals from existing clients, which we view as the strongest possible endorsement of the work we do.
      </p>
      <p class="text-gray-700 leading-relaxed">
        Our commitment to responsive communication is not a marketing promise — it is a practice standard. Every team member understands that timely, clear communication is a core part of what we deliver, and we hold ourselves accountable to meeting that standard every day.
      </p>
    </div>

    <!-- Team Member Cards -->
    <h2 class="text-2xl font-bold font-heading mb-6" style="color: #1C1C1E;">The ProAxis Team</h2>
    <div class="space-y-8 mb-14">
      {teamMembers.map((member) => (
        <div class="rounded-xl border border-gray-200 overflow-hidden" aria-label={`Team member: ${member.title}`}>
          <div class="flex flex-col sm:flex-row">
            <!-- Photo Placeholder -->
            <div class="w-full sm:w-48 flex-shrink-0 flex items-center justify-center" style="background-color: #F7F8FA; min-height: 200px;" aria-label="Team member photo placeholder">
              <div class="text-center p-6">
                <div class="w-20 h-20 rounded-full mx-auto mb-3 flex items-center justify-center" style="background-color: #1C1C1E;">
                  <svg class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
                <p class="text-xs text-gray-400">Photo coming soon</p>
              </div>
            </div>
            <!-- Content -->
            <div class="p-6 flex-1">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
                <h3 class="text-xl font-bold font-heading" style="color: #1C1C1E;">{member.name}</h3>
                <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full text-white" style="background-color: #2E75B6;">{member.credentials}</span>
              </div>
              <p class="text-sm font-semibold mb-3" style="color: #C5A55A;">{member.title}</p>
              <p class="text-gray-700 text-sm leading-relaxed mb-4">{member.bio}</p>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide mb-2" style="color: #1C1C1E;">Specializations</p>
                <div class="flex flex-wrap gap-2">
                  {member.specializations.map((spec) => (
                    <span class="text-xs px-2.5 py-1 rounded-md font-medium border border-gray-200" style="background-color: #F7F8FA; color: #1C1C1E;">{spec}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Credentials Section -->
    <section class="mb-12 rounded-xl p-8" style="background-color: #F7F8FA;">
      <h2 class="text-2xl font-bold font-heading mb-5" style="color: #1C1C1E;">Our Credentials &amp; Commitment to Clients</h2>
      <ul class="space-y-3 text-gray-700">
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 mt-0.5 flex-shrink-0" style="color: #22C55E;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span><strong>Active NJ CPA licensure:</strong> Our CPAs hold active licenses issued by the New Jersey State Board of Accountancy and fulfill the required continuing professional education annually.</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 mt-0.5 flex-shrink-0" style="color: #22C55E;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span><strong>AICPA membership:</strong> Our CPAs are members of the American Institute of Certified Public Accountants, adhering to the profession's code of professional conduct and ethical standards.</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 mt-0.5 flex-shrink-0" style="color: #22C55E;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span><strong>NJ Society of CPAs:</strong> We stay current with New Jersey-specific tax developments through membership and engagement with the New Jersey Society of Certified Public Accountants.</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 mt-0.5 flex-shrink-0" style="color: #22C55E;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span><strong>Technology certifications:</strong> Our team is trained and certified on leading cloud accounting platforms including QuickBooks Online, Xero, and related tools, ensuring efficient and accurate digital workflows.</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 mt-0.5 flex-shrink-0" style="color: #22C55E;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span><strong>IRS Authorized e-File Provider:</strong> ProAxis is an authorized IRS e-file provider, ensuring secure and timely electronic filing for all tax returns.</span>
        </li>
      </ul>
    </section>

    <!-- Join the Team CTA -->
    <div class="text-center py-8 rounded-xl border border-gray-200" style="background-color: #F7F8FA;">
      <p class="text-gray-600 mb-2">Interested in joining the ProAxis team?</p>
      <a href="/contact/" class="font-semibold hover:underline" style="color: #2E75B6;">Reach out through our contact page</a>
    </div>
  </section>

  <CTASection heading="Work Directly with Our CPA Team" subheading="Schedule a free consultation with the ProAxis team. Get to know us and tell us about your situation — no pressure, just expert conversation." />
</BaseLayout>
