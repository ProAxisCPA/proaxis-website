---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/ui/CTASection.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';

const city = "SoHo";
const state = "NY";
const title = "CPA for SoHo NYC Clients | NJ-NY Tax Specialists | ProAxis";
const description = "SoHo NYC CPA for creative professionals, fashion founders & tech entrepreneurs. S-Corp election, royalties, NJ LLC for UBT, QBI deduction & SEP-IRA planning. Virtual.";
const canonical = "/service-areas/soho/";
const breadcrumbs = [
  { name: "Service Areas", url: "/service-areas/" },
  { name: city }
];
const schema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "AccountingService"],
  "name": "ProAxis Tax & Accounting Services",
  "telephone": "+12018002330",
  "email": "info@proaxiscpa.com",
  "url": "https://www.proaxiscpa.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Hasbrouck Heights",
    "addressRegion": "NJ",
    "postalCode": "07604",
    "addressCountry": "US"
  },
  "areaServed": { "@type": "City", "name": "SoHo, NY" }
