const description = "ProAxis Tax & Accounting provides specialized CPA services for construction companies and contractors in New Jersey — job costing, WIP schedules, percentage-of-completion accounting, NJ prevailing wage compliance, and contractor tax strategy.";
const canonical = "/industries/construction/";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Construction & Contractor Accounting Services",
  "description": "Specialized accounting and tax services for construction companies and contractors in New Jersey, including job costing, WIP schedules, percentage-of-completion accounting, and NJ prevailing wage compliance.",
  "provider": {
    "@type": "AccountingService",
    "name": "ProAxis Tax & Accounting Services",
    "telephone": "+12018002330"
  },
  "areaServed": { "@type": "State", "name": "New Jersey" }
};

const breadcrumbs = [
  { name: "Industries", url: "/industries/" },
  { name: "Construction" }
];

const services = [
  { title: "Construction Bookkeeping", href: "/business-services/bookkeeping/" },
  { title: "Tax Planning & Strategy", href: "/tax-services/tax-planning/" },
  { title: "Payroll Services", href: "/business-services/payroll/" },
