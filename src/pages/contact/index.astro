---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import CTASection from '../../components/ui/CTASection.astro';

const title = "Contact ProAxis CPA | Schedule Free Consultation | Bergen County NJ";
const description = "Contact ProAxis Tax & Accounting Services in Bergen County, NJ. Schedule your free consultation online, call (201) 800-2330, or email info@proaxiscpa.com. 100% virtual service.";
const canonical = "/contact/";
const breadcrumbs = [{ name: "Contact" }];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact ProAxis Tax & Accounting Services",
    "description": "Schedule a free consultation with ProAxis Tax & Accounting Services in Bergen County, NJ.",
    "url": "https://www.proaxiscpa.com/contact/",
    "mainEntity": {
      "@type": "AccountingService",
      "name": "ProAxis Tax & Accounting Services",
      "telephone": "+12018002330",
      "email": "info@proaxiscpa.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Hasbrouck Heights",
        "addressRegion": "NJ",
        "postalCode": "07604",
        "addressCountry": "US"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "09:00",
          "closes": "17:00"
        }
      ]
    }
  }
];

const services = [
  "Tax Preparation",
  "Tax Planning & Strategy",
  "NJ SALT Consulting",
  "IRS Tax Resolution",
  "Estate & Gift Tax Planning",
  "Multi-State Tax Compliance",
  "Bookkeeping & Accounting",
  "Fractional CFO Services",
  "Payroll Services",
  "Financial Statements",
  "Startup Advisory",
  "Financial Technology Consulting",
  "Other / Not Sure Yet",
];
---

<BaseLayout {title} {description} {canonical} {schema} {breadcrumbs}>
  <Breadcrumbs items={breadcrumbs} />

  <!-- Hero -->
  <section style="background: linear-gradient(135deg, #1B2A4A 0%, #2E75B6 100%);" class="py-14 lg:py-18" aria-labelledby="contact-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 id="contact-heading" class="text-3xl sm:text-4xl lg:text-5xl font-bold font-heading text-white mb-4">
        Schedule Your Free Consultation
      </h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        Ready to work with a CPA firm that actually gets back to you? Fill out the form below, call us directly, or send an email — we'll respond within one business day.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Contact Form -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
          <h2 class="text-2xl font-bold font-heading mb-2" style="color: #1B2A4A;">Tell Us About Your Needs</h2>
          <p class="text-gray-600 mb-6">Complete the form below and a member of our team will reach out within one business day to schedule your free 30-minute consultation.</p>

          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/contact/thank-you/"
            class="space-y-5"
            aria-label="Contact form"
          >
            <!-- Netlify honeypot -->
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden">
              <label>Don't fill this out if you're human: <input name="bot-field" /></label>
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="first-name" class="block text-sm font-semibold mb-1.5" style="color: #1B2A4A;">First Name <span class="text-red-500" aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="first-name"
                  name="first-name"
                  required
                  autocomplete="given-name"
                  class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition-colors"
                  placeholder="John"
                  aria-required="true"
                />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-semibold mb-1.5" style="color: #1B2A4A;">Last Name <span class="text-red-500" aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="last-name"
                  name="last-name"
                  required
                  autocomplete="family-name"
                  class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition-colors"
                  placeholder="Smith"
                  aria-required="true"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="email" class="block text-sm font-semibold mb-1.5" style="color: #1B2A4A;">Email Address <span class="text-red-500" aria-hidden="true">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition-colors"
                  placeholder="john@yourbusiness.com"
                  aria-required="true"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold mb-1.5" style="color: #1B2A4A;">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  autocomplete="tel"
                  class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition-colors"
                  placeholder="(201) 555-0123"
                />
              </div>
            </div>

            <div>
              <label for="business-name" class="block text-sm font-semibold mb-1.5" style="color: #1B2A4A;">Business Name <span class="text-gray-400 font-normal">(if applicable)</span></label>
              <input
                type="text"
                id="business-name"
                name="business-name"
                autocomplete="organization"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition-colors"
                placeholder="Your Business LLC"
              />
            </div>

            <div>
              <label for="service" class="block text-sm font-semibold mb-1.5" style="color: #1B2A4A;">Service You're Interested In <span class="text-red-500" aria-hidden="true">*</span></label>
              <select
                id="service"
                name="service"
                required
                class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition-colors bg-white"
                aria-required="true"
              >
                <option value="" disabled selected>Select a service...</option>
                {services.map(s => <option value={s}>{s}</option>)}
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold mb-1.5" style="color: #1B2A4A;">Tell Us About Your Situation <span class="text-red-500" aria-hidden="true">*</span></label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition-colors resize-none"
                placeholder="Briefly describe your tax or accounting needs, business type, and any specific challenges you're facing..."
                aria-required="true"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-lg text-base font-semibold text-white transition-all hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2"
              style="background-color: #22C55E;"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
              Send Message & Request Consultation
            </button>
            <p class="text-xs text-gray-500 mt-2">By submitting this form, you agree to our <a href="/privacy-policy/" class="underline hover:text-blue-600">Privacy Policy</a>. We'll never sell your information.</p>
          </form>
        </div>
      </div>

      <!-- Contact Info Sidebar -->
      <div class="space-y-6">
        <!-- Direct Contact -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
          <h2 class="text-lg font-bold font-heading mb-4" style="color: #1B2A4A;">Contact Us Directly</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: #EEF3FA;">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #2E75B6;" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-gray-500 font-medium">Phone</div>
                <a href="tel:+12018002330" class="font-semibold text-sm hover:text-blue-700 transition-colors" style="color: #1B2A4A;">(201) 800-2330</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: #EEF3FA;">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #2E75B6;" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-gray-500 font-medium">Email</div>
                <a href="mailto:info@proaxiscpa.com" class="font-semibold text-sm hover:text-blue-700 transition-colors" style="color: #1B2A4A;">info@proaxiscpa.com</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: #EEF3FA;">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #2E75B6;" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-gray-500 font-medium">Virtual Meetings</div>
                <div class="font-semibold text-sm" style="color: #1B2A4A;">Zoom / Google Meet</div>
                <div class="text-xs text-gray-500">Available by appointment</div>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: #EEF3FA;">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #2E75B6;" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-gray-500 font-medium">Business Hours</div>
                <div class="font-semibold text-sm" style="color: #1B2A4A;">Mon–Fri: 9:00 AM – 5:00 PM</div>
                <div class="text-xs text-gray-500">Eastern Time</div>
              </div>
            </div>
          </div>
        </div>

        <!-- What to Expect -->
        <div class="rounded-2xl p-6" style="background-color: #F7F8FA; border: 1px solid #E5E7EB;">
          <h2 class="text-lg font-bold font-heading mb-4" style="color: #1B2A4A;">What Happens Next?</h2>
          <ol class="space-y-3">
            {[
              "We'll review your message within one business day",
              "A ProAxis CPA will reach out to schedule your free 30-minute consultation",
              "During the call, we'll discuss your needs and how we can help",
              "You'll receive a clear proposal — no jargon, no surprises",
            ].map((step, i) => (
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 text-xs font-bold text-white" style="background-color: #2E75B6;">{i + 1}</div>
                <span class="text-sm text-gray-700">{step}</span>
              </li>
            ))}
          </ol>
        </div>

        <!-- Location -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
          <h2 class="text-lg font-bold font-heading mb-3" style="color: #1B2A4A;">Our Location</h2>
          <p class="text-sm text-gray-600 mb-3">
            <strong>ProAxis Tax & Accounting Services</strong><br />
            Hasbrouck Heights, NJ 07604<br />
            <em class="text-xs">Fully virtual — no office visits required</em>
          </p>
          <!-- Google Maps embed -->
          <div class="rounded-lg overflow-hidden">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3014.5889!2d-74.0776!3d40.8598!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c2f95a6e3a1f8d%3A0x0!2sHasbrouck+Heights%2C+NJ+07604!5e0!3m2!1sen!2sus!4v1711300000000"
              width="100%"
              height="200"
              style="border:0;"
              allowfullscreen={false}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="ProAxis Tax & Accounting Services location in Hasbrouck Heights, NJ"
              aria-label="Google Maps showing Hasbrouck Heights, NJ 07604"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
