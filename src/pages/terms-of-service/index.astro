---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
const title = "Terms of Service | ProAxis Tax & Accounting Services";
const description = "Terms of service for ProAxis Tax & Accounting Services website and professional services.";
const canonical = "/terms-of-service/";
const breadcrumbs = [{ name: "Terms of Service" }];
---
<BaseLayout {title} {description} {canonical} breadcrumbs={breadcrumbs}>
  <Breadcrumbs items={breadcrumbs} />
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <h1 class="text-3xl font-bold font-heading mb-2" style="color: #1B2A4A;">Terms of Service</h1>
    <p class="text-gray-500 text-sm mb-8">Last Updated: March 2026</p>
    <div class="prose-proaxis">
      <p>By accessing and using the website at www.proaxiscpa.com, you agree to be bound by these Terms of Service. Please read them carefully.</p>
      <h2>Use of Website</h2>
      <p>This website is provided for general informational purposes about ProAxis Tax & Accounting Services and our professional services. You may use this website for lawful purposes only. You agree not to use this website in any way that violates applicable laws or regulations, or that could damage, disable, or impair the website or interfere with any other party's use.</p>
      <h2>Not Legal or Tax Advice</h2>
      <p>The content on this website is for informational purposes only and does not constitute legal, tax, accounting, or financial advice. The information on this site may not apply to your specific situation. You should consult with a licensed CPA or tax professional regarding your specific circumstances. An engagement letter must be signed before a CPA-client relationship is established with ProAxis.</p>
      <h2>No CPA-Client Relationship</h2>
      <p>Visiting this website, submitting the contact form, or sending us an email does not create a CPA-client relationship. A CPA-client relationship is only established upon execution of a formal engagement letter between you and ProAxis Tax & Accounting Services.</p>
      <h2>Intellectual Property</h2>
      <p>All content on this website, including text, graphics, logos, and images, is the property of ProAxis Tax & Accounting Services or its content suppliers and is protected by applicable intellectual property laws. You may not reproduce, distribute, or create derivative works without our express written permission.</p>
      <h2>Limitation of Liability</h2>
      <p>ProAxis Tax & Accounting Services shall not be liable for any indirect, incidental, special, or consequential damages arising out of or in connection with your use of this website or reliance on any information provided herein.</p>
      <h2>Links to Third-Party Sites</h2>
      <p>Our website may contain links to third-party websites. We have no control over and assume no responsibility for the content or privacy practices of any third-party sites.</p>
      <h2>Governing Law</h2>
      <p>These Terms of Service are governed by the laws of the State of New Jersey, without regard to its conflict of law provisions.</p>
      <h2>Contact</h2>
      <p>Questions about these Terms? Contact us at <a href="mailto:info@proaxiscpa.com">info@proaxiscpa.com</a> or (201) 800-2330.</p>
    </div>
  </div>
</BaseLayout>
